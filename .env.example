# Resend (contact form + audit lead emails)
# Sign up at resend.com with mark@averde.ai (separate account from MeetingBriefs)
# Authenticate averde.ai under Domains, then create a Sending API key
RESEND_API_KEY=

# Supabase (audit lead logging — uses the averde-app project)
SUPABASE_URL=https://zcnmujvgriynzpumvqks.supabase.co
SUPABASE_SERVICE_ROLE_KEY=

# Perplexity (AI search visibility check during audit)
# Sign up at perplexity.ai/settings/api, scope key to /search at minimum
PERPLEXITY_API_KEY=

# Google PageSpeed Insights API key (free, 25k queries/day per project)
# Without this we share the public anonymous quota and get rate-limited.
# Get one at: https://console.cloud.google.com/apis/credentials
# Enable "PageSpeed Insights API" on the project first.
PAGESPEED_API_KEY=

# Google Analytics 4 measurement id (G-XXXXXXXXXX). Optional — analytics only
# loads on production when this is set. Leave blank to disable. Find it under
# GA4 → Admin → Data Streams → your web stream. (Prefer cookieless? Swap the
# snippet in SEOHead.astro for Plausible or Cloudflare Web Analytics.)
PUBLIC_GA_ID=

# Your GitHub username (the account that owns the averde-ai repo)
GITHUB_OWNER=mjbloomfield

# Generated automatically by the Keystatic GitHub setup wizard
# Visit /keystatic on your deployed site to run it
KEYSTATIC_GITHUB_CLIENT_ID=
KEYSTATIC_GITHUB_CLIENT_SECRET=
KEYSTATIC_SECRET=
PUBLIC_KEYSTATIC_GITHUB_APP_SLUG=
