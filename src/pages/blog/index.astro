---
import { getCollection } from 'astro:content';
import BaseLayout from '../../layouts/BaseLayout.astro';

const allPosts = await getCollection('blog');
const posts = allPosts.sort((a, b) => {
  const dateA = a.data.publishedDate ? new Date(a.data.publishedDate).getTime() : 0;
  const dateB = b.data.publishedDate ? new Date(b.data.publishedDate).getTime() : 0;
  return dateB - dateA;
});

const categoryColors: Record<string, string> = {
  'Voice AI': 'bg-green-sage/10 text-green-mid',
  'Pricing': 'bg-sand/20 text-terracotta',
  'Dental': 'bg-blue-50 text-blue-700',
  'HVAC': 'bg-orange-50 text-orange-700',
  'Plumbing': 'bg-cyan-50 text-cyan-700',
  'Real Estate': 'bg-purple-50 text-purple-700',
  'Automation': 'bg-purple-50 text-purple-700',
  'Case Study': 'bg-green-50 text-green-700',
};
---

<BaseLayout
  title="AI Voice Agent Resources | Averde AI Blog"
  description="Practical guides on AI voice agents, missed call recovery, and growing your service business. From Averde AI in Boulder, CO."
>

  <!-- HERO -->
  <section class="bg-green-deep py-20 text-center">
    <div class="max-w-3xl mx-auto px-4 sm:px-6">
      <h1 class="text-5xl font-extrabold text-white-warm mb-5">Resources</h1>
      <p class="text-cream/70 text-xl">Practical guides on AI voice agents, automation, and growing your service business.</p>
    </div>
  </section>

  <!-- POSTS -->
  <section class="bg-cream py-20">
    <div class="max-w-5xl mx-auto px-4 sm:px-6">

      {posts.length > 0 ? (
        <div class="grid grid-cols-1 md:grid-cols-2 gap-8 mb-16">
          {posts.map(post => (
            <article class="bg-white-warm rounded-2xl p-8 flex flex-col hover:shadow-md transition-shadow">
              <div class="flex items-center gap-2 mb-4">
                <span class={`text-xs font-semibold px-2.5 py-1 rounded-full ${categoryColors[post.data.category] || 'bg-gray-100 text-gray-600'}`}>
                  {post.data.category}
                </span>
                {post.data.publishedDate && (
                  <span class="text-xs text-muted">
                    {new Date(post.data.publishedDate).toLocaleDateString('en-US', { month: 'long', day: 'numeric', year: 'numeric' })}
                  </span>
                )}
              </div>
              <h2 class="text-xl font-bold text-green-deep mb-3 leading-snug flex-1">
                {post.data.title}
              </h2>
              <p class="text-muted text-sm leading-relaxed mb-5">{post.data.excerpt}</p>
              <a href={`/blog/${post.slug}`} class="text-green-mid text-sm font-semibold hover:text-green-deep transition-colors">
                Read more →
              </a>
            </article>
          ))}
        </div>
      ) : (
        <div class="text-center py-12 mb-16">
          <p class="text-muted text-lg">Posts coming soon — subscribe below to get notified.</p>
        </div>
      )}

      <!-- Subscribe nudge -->
      <div class="bg-green-deep rounded-3xl p-10 text-center">
        <h2 class="text-2xl font-bold text-cream mb-3">Get notified when posts go live</h2>
        <p class="text-cream/60 mb-6">Practical AI guides for small business owners — no fluff, no spam.</p>
        <a href="mailto:mark@averde.ai?subject=Blog updates" class="inline-flex items-center bg-sand text-green-deep font-semibold px-6 py-3 rounded-xl hover:bg-sand/90 transition-colors">
          Email mark@averde.ai to subscribe
        </a>
      </div>
    </div>
  </section>

</BaseLayout>
