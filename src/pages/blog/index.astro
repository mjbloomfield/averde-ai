---
import { getCollection } from 'astro:content';
import BaseLayout from '../../layouts/BaseLayout.astro';
import SubscribeForm from '../../components/SubscribeForm.astro';
import { createReader } from '@keystatic/core/reader';
import keystaticConfig from '../../../keystatic.config';

const reader = createReader(process.cwd(), keystaticConfig);
const header = await reader.singletons.blogIndex.read();

const allPosts = await getCollection('blog');
// Scheduled-publish filter: hide posts whose publishedDate is in the future.
// Set a future date in Keystatic and the post stays invisible until that
// date passes AND the site is rebuilt. (Free — no cron required if you
// commit/deploy weekly anyway.)
const now = Date.now();
const posts = allPosts
  .filter(p => {
    if (!p.data.publishedDate) return true;
    return new Date(p.data.publishedDate).getTime() <= now;
  })
  .sort((a, b) => {
    const dateA = a.data.publishedDate ? new Date(a.data.publishedDate).getTime() : 0;
    const dateB = b.data.publishedDate ? new Date(b.data.publishedDate).getTime() : 0;
    return dateB - dateA;
  });

const categoryColors: Record<string, string> = {
  'Pricing': 'bg-sand/20 text-terracotta',
  'Dental': 'bg-blue-50 text-blue-700',
  'HVAC': 'bg-orange-50 text-orange-700',
  'Plumbing': 'bg-cyan-50 text-cyan-700',
  'Real Estate': 'bg-purple-50 text-purple-700',
  'Automation': 'bg-purple-50 text-purple-700',
  'Case Study': 'bg-green-50 text-green-700',
};
---

<BaseLayout
  title="Resources — AI for Small Business | Mark Bloomfield"
  description="Practical guides on getting your business found in AI search, AEO content, schema markup, and using AI to grow without the hype. From Boulder, CO."
>

  <!-- HERO -->
  <section class="bg-green-deep py-20 text-center">
    <div class="max-w-3xl mx-auto px-4 sm:px-6">
      <h1 class="text-5xl font-extrabold text-white-warm mb-5">{header?.title ?? 'Resources'}</h1>
      <p class="text-cream/70 text-xl">{header?.dek}</p>
    </div>
  </section>

  <!-- POSTS -->
  <section class="bg-cream py-20">
    <div class="max-w-5xl mx-auto px-4 sm:px-6">

      {posts.length > 0 ? (
        <div class="grid grid-cols-1 md:grid-cols-2 gap-8 mb-16">
          {posts.map(post => (
            <article class="bg-white-warm rounded-2xl p-8 flex flex-col hover:shadow-md transition-shadow">
              <div class="flex items-center gap-2 mb-4">
                <span class={`text-xs font-semibold px-2.5 py-1 rounded-full ${categoryColors[post.data.category] || 'bg-gray-100 text-gray-600'}`}>
                  {post.data.category}
                </span>
                {post.data.publishedDate && (
                  <span class="text-xs text-muted">
                    {new Date(post.data.publishedDate).toLocaleDateString('en-US', { month: 'long', day: 'numeric', year: 'numeric' })}
                  </span>
                )}
              </div>
              <h2 class="text-xl font-bold text-green-deep mb-3 leading-snug flex-1">
                {post.data.title}
              </h2>
              <p class="text-muted text-sm leading-relaxed mb-5">{post.data.excerpt}</p>
              <a href={`/blog/${post.id}`} class="text-green-mid text-sm font-semibold hover:text-green-deep transition-colors">
                Read more →
              </a>
            </article>
          ))}
        </div>
      ) : (
        <div class="text-center py-12 mb-16">
          <p class="text-muted text-lg">{header?.emptyState}</p>
        </div>
      )}

      <!-- Subscribe nudge -->
      <SubscribeForm
        source="blog"
        heading="Get notified when posts go live"
        dek="Practical AI guides for small business owners — no fluff, no spam, unsubscribe anytime."
      />
    </div>
  </section>

</BaseLayout>
