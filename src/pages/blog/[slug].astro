---
import { getCollection, getEntry, render } from 'astro:content';
import BaseLayout from '../../layouts/BaseLayout.astro';

export async function getStaticPaths() {
  const posts = await getCollection('blog');
  // Scheduled-publish filter: don't generate routes for future-dated posts.
  // Set publishedDate in Keystatic to schedule.
  const now = Date.now();
  return posts
    .filter(p => !p.data.publishedDate || new Date(p.data.publishedDate).getTime() <= now)
    .map(post => ({ params: { slug: post.id } }));
}

const { slug } = Astro.params;
const post = await getEntry('blog', slug as string);
if (!post) return Astro.redirect('/blog');

const { Content } = await render(post);

const categoryColors: Record<string, string> = {
  'Pricing': 'bg-sand/20 text-terracotta',
  'Dental': 'bg-blue-50 text-blue-700',
  'HVAC': 'bg-orange-50 text-orange-700',
  'Plumbing': 'bg-cyan-50 text-cyan-700',
  'Real Estate': 'bg-purple-50 text-purple-700',
  'Automation': 'bg-purple-50 text-purple-700',
  'Case Study': 'bg-green-50 text-green-700',
};
---

<BaseLayout
  title={`${post.data.title} | Mark Bloomfield`}
  description={post.data.seoDescription || post.data.excerpt}
>

  <div class="bg-cream min-h-screen">
    <!-- Header -->
    <div class="relative bg-green-deep py-16 overflow-hidden">
      <div
        class="absolute inset-0 bg-cover bg-center"
        style="background-image: url('/images/textures/wood-beam-dark.jpg'); opacity: 0.35;"
        aria-hidden="true"
      ></div>
      <div
        class="absolute inset-0 bg-gradient-to-b from-green-deep/60 via-green-deep/40 to-green-deep/80"
        aria-hidden="true"
      ></div>
      <div class="relative max-w-3xl mx-auto px-4 sm:px-6">
        <a href="/free" class="text-cream/60 text-sm hover:text-cream mb-6 inline-block">← Back to Free Resources</a>
        <div class="flex items-center gap-3 mb-5">
          <span class={`text-xs font-semibold px-2.5 py-1 rounded-full ${categoryColors[post.data.category] || 'bg-white/10 text-white'}`}>
            {post.data.category}
          </span>
          {post.data.publishedDate && (
            <span class="text-cream/60 text-sm">
              {new Date(post.data.publishedDate).toLocaleDateString('en-US', { month: 'long', day: 'numeric', year: 'numeric' })}
            </span>
          )}
        </div>
        <h1 class="text-4xl font-extrabold text-cream leading-tight mb-4">
          {post.data.title}
        </h1>
        <p class="text-cream/70 text-lg">{post.data.excerpt}</p>
        {post.data.author && (
          <p class="text-cream/50 text-sm mt-4">By {post.data.author}</p>
        )}
      </div>
    </div>

    <!-- Content -->
    <div class="max-w-3xl mx-auto px-4 sm:px-6 py-16">
      <div class="bg-cream rounded-2xl p-8 sm:p-12 prose prose-lg max-w-none
        prose-headings:text-green-deep
        prose-p:text-dark prose-p:leading-relaxed
        prose-a:text-green-mid prose-a:no-underline hover:prose-a:underline
        prose-strong:text-green-deep
        prose-li:text-dark
        prose-h2:text-2xl prose-h3:text-xl prose-h2:mt-10 prose-h2:mb-4
        prose-h3:mt-8 prose-h3:mb-3">
        <Content />
      </div>
    </div>
  </div>

</BaseLayout>
