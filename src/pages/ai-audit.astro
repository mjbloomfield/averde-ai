---
import BaseLayout from '../layouts/BaseLayout.astro';
---

<BaseLayout
  title="Free AI Visibility Audit | Live Checks on Your Real Website"
  description="We fetch your live website, check the 13 things AI engines actually read, and run a real AI-search query for your market. See exactly what passes, what fails, and how to fix each one — free, in about 3 minutes."
>

  <!-- HERO -->
  <section class="bg-green-deep py-16 text-center">
    <div class="max-w-3xl mx-auto px-4 sm:px-6">
      <div class="inline-flex items-center gap-2 bg-sand/20 text-sand text-xs font-semibold px-3 py-1.5 rounded-full mb-5">
        Free · Live checks on your real site · ~3 minutes · No credit card
      </div>
      <h1 class="text-4xl md:text-5xl font-extrabold text-white-warm leading-tight mb-5">
        Can AI find your business?
      </h1>
      <p class="text-cream/70 text-lg">
        This isn't a quiz with a made-up score. The audit fetches your live website, checks the
        13 things AI engines actually read — schema markup, page structure, speed, crawl files —
        and runs a real AI-search query for your market. You'll see exactly what passed, what
        failed, and how to fix each one yourself.
      </p>
    </div>
  </section>

  <!-- WIDGET -->
  <section class="bg-cream pt-10 pb-16">
    <div class="max-w-5xl mx-auto px-4 sm:px-6">
      <iframe
        id="audit-frame"
        src="/audit/index.html"
        title="AI Visibility Audit"
        style="width:100%; min-height:900px; border:0; display:block; background:transparent;"
        loading="lazy"
      ></iframe>
      <script is:inline>
        // The widget posts its height after each render — keep the iframe snug.
        window.addEventListener('message', (e) => {
          if (e.data && typeof e.data.auditHeight === 'number') {
            document.getElementById('audit-frame').style.minHeight =
              Math.max(600, e.data.auditHeight + 40) + 'px';
          }
        });
      </script>
    </div>
  </section>

  <!-- BOOK A REVIEW CALL -->
  <section id="book" class="bg-white-warm py-16 scroll-mt-20">
    <div class="max-w-4xl mx-auto px-4 sm:px-6">
      <div class="text-center mb-10">
        <p class="text-sand text-xs font-semibold uppercase tracking-widest mb-3">Got your report?</p>
        <h2 class="text-3xl md:text-4xl font-extrabold text-green-deep mb-4">
          Ready to walk through it together?
        </h2>
        <p class="text-muted text-lg max-w-2xl mx-auto">
          Pick a time below for a free 30-minute working session with me. I'll go through your
          report, answer questions, and turn it into a concrete plan you can actually act on —
          whether or not you hire me for any of it.
        </p>
      </div>

      <div class="bg-cream rounded-3xl p-6 sm:p-8 shadow-sm">
        <p class="font-bold text-green-deep text-lg mb-1">Book your free 30-minute review call</p>
        <p class="text-muted text-sm mb-5">Pick a time that works for you — I'll confirm by email.</p>
        <div class="tidycal-embed" data-path="199qry1"></div>
        <script src="https://asset-tidycal.b-cdn.net/js/embed.js" async></script>
      </div>

      <p class="mt-6 text-center text-muted text-sm">
        Or reach out directly: <a href="mailto:mark@averde.ai" class="text-green-mid font-medium hover:text-green-deep">mark@averde.ai</a>
      </p>
    </div>
  </section>

</BaseLayout>
