---
import BaseLayout from '../layouts/BaseLayout.astro';
import { createReader } from '@keystatic/core/reader';
import keystaticConfig from '../../keystatic.config';
import { renderInlineMarkdown } from '../lib/markdown';

const reader = createReader(process.cwd(), keystaticConfig);
const page = await reader.singletons.aiAudit.read();
const settings = await reader.singletons.settings.read();

const email = settings?.email ?? 'mark@averde.ai';
const audits = page?.audits ?? [];
---

<BaseLayout
  title={page?.seoTitle ?? 'Free AI Audits | Averde AI'}
  description={page?.seoDescription ?? ''}
>

  <!-- HERO -->
  <section class="wood-medium bg-green-deep py-16 text-center">
    <div class="max-w-3xl mx-auto px-4 sm:px-6">
      <div class="inline-flex items-center gap-2 bg-sand/20 text-sand text-xs font-semibold px-3 py-1.5 rounded-full mb-5">
        {page?.heroBadge}
      </div>
      <h1 class="text-4xl md:text-5xl font-extrabold text-cream leading-tight mb-5">
        {page?.heroHeadline}
      </h1>
      <p
        class="text-cream/70 text-lg [&_strong]:text-cream [&_a]:text-cream [&_a]:underline [&_a]:decoration-dotted [&_a]:underline-offset-4 [&_a:hover]:text-sand"
        set:html={renderInlineMarkdown(page?.heroDek ?? '')}
      />
    </div>
  </section>

  <!-- TWO AUDITS -->
  <section class="bg-cream topo-map topo-bear pt-14 pb-4">
    <div class="max-w-5xl mx-auto px-4 sm:px-6">
      <div class="grid md:grid-cols-2 gap-6 items-stretch">
        {audits.map((a) => (
          <div class="bg-cream rounded-3xl p-8 shadow-sm flex flex-col">
            <p class="text-sand text-xs font-semibold uppercase tracking-widest mb-3">{a.eyebrow}</p>
            <h2 class="text-2xl font-extrabold text-green-deep mb-3">{a.title}</h2>
            <p class="text-muted leading-relaxed mb-6">{a.body}</p>
            <a href={a.ctaHref} class="mt-auto inline-block text-center bg-green-deep text-cream font-semibold px-6 py-3.5 rounded-xl hover:bg-green-mid transition-colors">
              {a.ctaLabel}
            </a>
          </div>
        ))}
      </div>
    </div>
  </section>

  <!-- WIDGET -->
  <section id="website-audit" class="bg-cream pt-10 pb-16 scroll-mt-20">
    <div class="max-w-5xl mx-auto px-4 sm:px-6">
      <iframe
        id="audit-frame"
        src="/audit/index.html"
        title="Website Audit"
        style="width:100%; min-height:900px; border:0; display:block; background:transparent;"
        loading="lazy"
      ></iframe>
      <script is:inline>
        // The widget posts its height after each render — keep the iframe snug.
        window.addEventListener('message', (e) => {
          if (e.data && typeof e.data.auditHeight === 'number') {
            document.getElementById('audit-frame').style.minHeight =
              Math.max(600, e.data.auditHeight + 40) + 'px';
          }
        });
      </script>
    </div>
  </section>

  <!-- BOOK A REVIEW CALL -->
  <section id="book" class="bg-cream py-16 scroll-mt-20">
    <div class="max-w-4xl mx-auto px-4 sm:px-6">
      <div class="text-center mb-10">
        <p class="text-sand text-xs font-semibold uppercase tracking-widest mb-3">{page?.bookEyebrow}</p>
        <h2 class="text-3xl md:text-4xl font-extrabold text-green-deep mb-4">
          {page?.bookHeadline}
        </h2>
        <p class="text-muted text-lg max-w-2xl mx-auto">
          {page?.bookDek}
        </p>
      </div>

      <div class="bg-cream rounded-3xl p-6 sm:p-8 shadow-sm">
        <p class="font-bold text-green-deep text-lg mb-1">{page?.bookCardTitle}</p>
        <p class="text-muted text-sm mb-5">{page?.bookCardSub}</p>
        <iframe src="https://calendar.google.com/calendar/appointments/schedules/AcZssZ1XF6Cd-RbjfwRu8rZj39AY7nVMemRVBTh2jn945OnAZvRFVeB80FFFRZusXERELC5DecVHma6u?gv=true" style="border:0" width="100%" height="700" frameborder="0" title="Book a call with Mark"></iframe>
      </div>

      <p class="mt-6 text-center text-muted text-sm">
        {page?.bookAltLine} <a href={`mailto:${email}`} class="text-green-mid font-medium hover:text-green-deep">{email}</a>
      </p>
    </div>
  </section>

</BaseLayout>
