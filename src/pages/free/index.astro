---
import { getCollection } from 'astro:content';
import BaseLayout from '../../layouts/BaseLayout.astro';
import SubscribeForm from '../../components/SubscribeForm.astro';
import { createReader } from '@keystatic/core/reader';
import keystaticConfig from '../../../keystatic.config';

const reader = createReader(process.cwd(), keystaticConfig);
const page = await reader.singletons.freeIndex.read();

// Published posts (scheduled-publish filter: future-dated posts stay hidden
// until their date passes and the site rebuilds).
const now = Date.now();
const posts = (await getCollection('blog'))
  .filter(p => !p.data.publishedDate || new Date(p.data.publishedDate).getTime() <= now)
  .sort((a, b) => {
    const dateA = a.data.publishedDate ? new Date(a.data.publishedDate).getTime() : 0;
    const dateB = b.data.publishedDate ? new Date(b.data.publishedDate).getTime() : 0;
    return dateB - dateA;
  });

// Multi-part series group under their own headers; standalone posts keep cards.
type Post = (typeof posts)[number];
const seriesMap = new Map<string, Post[]>();
for (const post of posts) {
  const name = post.data.series;
  if (!name) continue;
  if (!seriesMap.has(name)) seriesMap.set(name, []);
  seriesMap.get(name)!.push(post);
}
for (const parts of seriesMap.values()) parts.sort((a, b) => (a.data.seriesPart ?? 0) - (b.data.seriesPart ?? 0));
const seriesList = [...seriesMap.entries()];
const standalone = posts.filter(p => !p.data.series);

const downloads = page?.downloads ?? [];
---

<BaseLayout
  title="Free Resources — AI Articles, Tools & Templates | Averde AI"
  description="Free, no-catch resources for small business owners: practical articles on AI search and using AI, the Claude Starter Kit, and a plain-English glossary. No email gate."
>

  <!-- HERO -->
  <section class="wood-medium bg-green-deep py-16 text-center">
    <div class="max-w-3xl mx-auto px-4 sm:px-6">
      <h1 class="text-4xl md:text-5xl font-extrabold text-cream leading-tight mb-5">{page?.title}</h1>
      <p class="text-cream/70 text-lg">{page?.dek}</p>
    </div>
  </section>

  <!-- FREE AUDITS BAND -->
  <section class="bg-cream topo-map topo-sboulder pt-14 pb-4">
    <div class="max-w-5xl mx-auto px-4 sm:px-6">
      <div class="bg-cream rounded-3xl p-8 shadow-sm sm:flex items-center justify-between gap-8">
        <div>
          <p class="text-sand text-xs font-semibold uppercase tracking-widest mb-2">{page?.auditsEyebrow}</p>
          <h2 class="text-2xl font-extrabold text-green-deep mb-2">{page?.auditsHeadline}</h2>
          <p class="text-muted leading-relaxed">{page?.auditsDek}</p>
        </div>
        <a href="/ai-audit" class="mt-5 sm:mt-0 inline-block flex-shrink-0 bg-green-deep text-cream font-semibold px-6 py-3.5 rounded-xl hover:bg-green-mid transition-colors">
          {page?.auditsCta}
        </a>
      </div>
    </div>
  </section>

  <!-- FREE ARTICLES -->
  <section class="bg-cream topo-map topo-sboulder pt-12 pb-4">
    <div class="max-w-5xl mx-auto px-4 sm:px-6">
      <div class="mb-8">
        <h2 class="text-3xl font-extrabold text-green-deep mb-2">{page?.articlesHeading}</h2>
        <p class="text-muted">{page?.articlesDek}</p>
      </div>

      {seriesList.length > 0 && (
        <div class="space-y-8 mb-12">
          {seriesList.map(([name, parts]) => (
            <div class="bg-cream rounded-2xl p-8">
              <p class="text-sand text-xs font-semibold uppercase tracking-widest mb-2">{parts.length}-part series</p>
              <h3 class="text-2xl font-extrabold mb-5">
                <a href={`/blog/${parts[0].id}`} class="text-green-deep hover:text-green-mid transition-colors">{name}</a>
              </h3>
              <ol class="space-y-1">
                {parts.map(part => (
                  <li>
                    <a href={`/blog/${part.id}`} class="group flex items-baseline gap-3 py-1.5 -mx-2 px-2 rounded-lg hover:bg-bone/40 transition-colors">
                      <span class="text-sand font-bold text-sm whitespace-nowrap">Part {part.data.seriesPart}</span>
                      <span class="text-green-deep font-semibold underline decoration-transparent group-hover:decoration-current underline-offset-4 transition-colors">{part.data.title}</span>
                    </a>
                  </li>
                ))}
              </ol>
            </div>
          ))}
        </div>
      )}

      {standalone.length > 0 ? (
        <div class="grid grid-cols-1 md:grid-cols-2 gap-8 mb-12">
          {standalone.map(post => (
            <article class="bg-cream rounded-2xl p-8 flex flex-col hover:shadow-md transition-shadow">
              {post.data.publishedDate && (
                <p class="text-xs text-muted mb-4">
                  {new Date(post.data.publishedDate).toLocaleDateString('en-US', { month: 'long', day: 'numeric', year: 'numeric' })}
                </p>
              )}
              <h3 class="text-xl font-bold text-green-deep mb-3 leading-snug flex-1">{post.data.title}</h3>
              <p class="text-muted text-sm leading-relaxed mb-5">{post.data.excerpt}</p>
              <a href={`/blog/${post.id}`} class="text-green-mid text-sm font-semibold hover:text-green-deep transition-colors">
                Read more →
              </a>
            </article>
          ))}
        </div>
      ) : posts.length === 0 ? (
        <p class="text-muted text-lg mb-12">{page?.emptyState}</p>
      ) : null}
    </div>
  </section>

  <!-- FREE DOWNLOADS & REFERENCE -->
  <section class="bg-cream topo-map topo-sboulder pt-12 pb-16">
    <div class="max-w-5xl mx-auto px-4 sm:px-6">
      <div class="mb-8">
        <h2 class="text-3xl font-extrabold text-green-deep mb-2">{page?.downloadsHeading}</h2>
        <p class="text-muted">{page?.downloadsDek}</p>
      </div>
      <div class="grid grid-cols-1 md:grid-cols-2 gap-8 mb-16">
        {downloads.map(r => (
          <a href={r.href} class="block bg-cream rounded-3xl p-7 sm:p-8 hover:shadow-md transition-all">
            <p class="text-sand text-xs font-semibold uppercase tracking-widest mb-3">{r.tag}</p>
            <h3 class="text-xl font-bold text-green-deep mb-2">{r.title}</h3>
            <p class="text-muted text-sm leading-relaxed mb-4">{r.description}</p>
            <span class="text-green-mid text-sm font-semibold">{r.ctaLabel}</span>
          </a>
        ))}
      </div>

      <SubscribeForm
        source="free"
        heading="Get notified when new resources go live"
        dek="Practical AI guides for small business owners — no fluff, no spam, unsubscribe anytime."
      />
    </div>
  </section>

</BaseLayout>
