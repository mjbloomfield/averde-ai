---
import BaseLayout from '../layouts/BaseLayout.astro';
---

<BaseLayout
  title="Mark Bloomfield — Your Personal AI Guy | Averde AI"
  description="Mark Bloomfield helps small businesses and service providers cut through the AI noise. Free tools, $27 playbooks, strategy sessions, and custom builds. Boulder, CO."
  isHome={true}
>

  <!-- HERO — paper bg with visible wood grain -->
  <section class="hero">
    <!-- wood plank strip -->
    <div class="wood-strip" aria-hidden="true"></div>
    <div class="wrap hero-grid">
      <div class="hero-text">
        <span class="tag">Boulder, CO · Serving businesses nationwide</span>
        <h1>Your Personal<br/><em>AI Guy.</em></h1>
        <p class="hero-sub">
          I'm Mark Bloomfield — engineer, founder, and the person who explains AI to small
          businesses without the jargon or the hype. I help you figure out what's real,
          what's worth it, and how to actually make it work for you.
        </p>
        <div class="hero-ctas">
          <a href="/ai-audit" class="btn btn-primary">Get my free AI audit</a>
          <a href="#tools" class="btn btn-ghost">See free resources →</a>
        </div>
        <div class="hero-trust">
          <span>Free AI audit · No credit card</span>
          <span class="dot">·</span>
          <span>Results in 30 min</span>
          <span class="dot">·</span>
          <span>Boulder, CO</span>
        </div>
      </div>
      <div class="hero-card-wrap">
        <div class="hero-card">
          <div class="hero-card-img">
            <div class="hero-card-caption">
              <div class="caption-name">Mark Bloomfield</div>
              <div class="caption-role">Founder · Averde AI</div>
            </div>
          </div>
          <div class="hero-card-body">
            <div class="hero-card-tag">What I do</div>
            <ul class="hero-card-list">
              <li>Explain AI — plain English, no fluff</li>
              <li>Deploy tools that fit your business</li>
              <li>Build custom AI on your data</li>
            </ul>
          </div>
        </div>
        <div class="hero-badge">
          <div class="hero-badge-num">30</div>
          <div class="hero-badge-lbl">Min free audit</div>
        </div>
      </div>
    </div>
  </section>

  <!-- FREE TOOLS — dark walnut with visible wood grain -->
  <section class="section wood-dark" id="tools">
    <div class="wrap">
      <div class="section-head-split">
        <div>
          <span class="eyebrow eyebrow-light">Start here — no cost</span>
          <h2 class="light">Free tools to<br/>get you oriented.</h2>
        </div>
        <p class="dek-light">
          Not ready to buy anything yet? Good. These free resources will show you
          exactly where AI can help your business — and where it can't.
        </p>
      </div>
      <div class="tools-grid">
        <a href="/ai-audit" class="tool-card">
          <div class="tool-icon">
            <svg width="28" height="28" viewBox="0 0 28 28" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round">
              <circle cx="14" cy="14" r="10"/>
              <path d="M14 9v5l3 3"/>
            </svg>
          </div>
          <div class="tool-tag">30-min call · Free</div>
          <h3>Free AI Audit</h3>
          <p>30 minutes with me. I'll map out exactly where AI can help your business, what it'll cost, and what to expect — no pitch, no pressure.</p>
          <span class="tool-cta">Book your audit →</span>
        </a>
        <a href="#quiz" class="tool-card">
          <div class="tool-icon">
            <svg width="28" height="28" viewBox="0 0 28 28" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round">
              <path d="M6 8h16M6 13h12M6 18h8"/>
            </svg>
          </div>
          <div class="tool-tag">2-min quiz · Free</div>
          <h3>AI Readiness Quiz</h3>
          <p>Answer 8 quick questions and get a personalised AI readiness score — with specific recommendations for your type of business.</p>
          <span class="tool-cta">Take the quiz →</span>
        </a>
        <a href="#calculator" class="tool-card">
          <div class="tool-icon">
            <svg width="28" height="28" viewBox="0 0 28 28" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round">
              <rect x="6" y="4" width="16" height="20" rx="2"/>
              <path d="M10 10h8M10 14h5M10 18h3"/>
            </svg>
          </div>
          <div class="tool-tag">Instant · Free</div>
          <h3>Missed Call Calculator</h3>
          <p>Enter your average job value and how many calls you miss per week. I'll show you the exact revenue you're leaving on the table.</p>
          <span class="tool-cta">Calculate my loss →</span>
        </a>
      </div>
    </div>
  </section>

  <!-- $27 PLAYBOOKS — bone bg -->
  <section class="section section-bone">
    <div class="wrap">
      <div class="section-head">
        <span class="eyebrow">Start with something concrete</span>
        <h2>Industry AI Playbooks — $27</h2>
        <p class="dek">
          A step-by-step guide to the AI tools that actually move the needle in your industry.
          Built around how your business runs — not generic advice.
        </p>
      </div>
      <div class="playbooks-grid">
        <a href="/dental" class="playbook">
          <div class="playbook-industry">Dental Practices</div>
          <svg class="playbook-icon" viewBox="0 0 32 32" fill="none" stroke="currentColor" stroke-width="1.4" stroke-linecap="round" stroke-linejoin="round">
            <path d="M10 6 C 8 6, 6 8, 6 12 C 6 18, 9 26, 12 26 C 14 26, 14 22, 16 22 C 18 22, 18 26, 20 26 C 23 26, 26 18, 26 12 C 26 8, 24 6, 22 6 C 20 6, 18 8, 16 8 C 14 8, 12 6, 10 6 Z"/>
          </svg>
          <h3>The Dental Practice AI Playbook</h3>
          <p>AI tools for scheduling, recalls, insurance FAQs, and front-desk overflow — written for practice owners, not IT departments.</p>
          <div class="playbook-includes">
            <strong>What's inside</strong>
            <ul>
              <li>The 3 AI tools every dental practice should have first</li>
              <li>How to answer calls 24/7 without adding staff</li>
              <li>Reducing no-shows with automated reminders</li>
              <li>Step-by-step setup guide — no tech skills needed</li>
            </ul>
          </div>
          <div class="playbook-buy">
            <span class="price">$27</span>
            <span class="buy-cta">Get the Playbook →</span>
          </div>
        </a>

        <a href="/hvac" class="playbook">
          <div class="playbook-industry">HVAC &amp; Contractors</div>
          <svg class="playbook-icon" viewBox="0 0 32 32" fill="none" stroke="currentColor" stroke-width="1.4" stroke-linecap="round" stroke-linejoin="round">
            <path d="M13 4 L 19 4 L 19 10 L 24 10 L 28 14 L 28 20 L 24 24 L 19 24 L 19 28 L 13 28 L 13 22 L 8 22 L 4 18 L 4 12 L 8 8 L 13 8 Z"/>
            <circle cx="16" cy="16" r="3"/>
          </svg>
          <h3>The HVAC &amp; Contractor AI Playbook</h3>
          <p>How to handle emergency calls at 2am, dispatch smarter, book jobs while your techs are on-site, and stop losing work to competitors who picked up first.</p>
          <div class="playbook-includes">
            <strong>What's inside</strong>
            <ul>
              <li>24/7 emergency triage — without hiring an answering service</li>
              <li>Scheduling and dispatch automation that actually works</li>
              <li>How to qualify and capture leads from every missed call</li>
              <li>The $300 tool that recovers a job a week</li>
            </ul>
          </div>
          <div class="playbook-buy">
            <span class="price">$27</span>
            <span class="buy-cta">Get the Playbook →</span>
          </div>
        </a>

        <a href="/real-estate" class="playbook">
          <div class="playbook-industry">Real Estate Agents</div>
          <svg class="playbook-icon" viewBox="0 0 32 32" fill="none" stroke="currentColor" stroke-width="1.4" stroke-linecap="round" stroke-linejoin="round">
            <path d="M4 16 L 16 6 L 28 16 L 26 16 L 26 26 L 18 26 L 18 20 L 14 20 L 14 26 L 6 26 L 6 16 Z"/>
          </svg>
          <h3>The Real Estate Agent AI Playbook</h3>
          <p>Be the first agent to respond — every time. Tools for qualifying leads instantly, scheduling showings 24/7, and following up without lifting a finger.</p>
          <div class="playbook-includes">
            <strong>What's inside</strong>
            <ul>
              <li>How to respond to every buyer lead in under 60 seconds</li>
              <li>AI screening questions that filter serious buyers from tire-kickers</li>
              <li>Showing scheduling automation that syncs to your calendar</li>
              <li>The follow-up sequence that books more listings</li>
            </ul>
          </div>
          <div class="playbook-buy">
            <span class="price">$27</span>
            <span class="buy-cta">Get the Playbook →</span>
          </div>
        </a>
      </div>
    </div>
  </section>

  <!-- DEEPER SERVICES — paper bg -->
  <section class="section">
    <div class="wrap">
      <div class="section-head">
        <span class="eyebrow">Ready to go deeper</span>
        <h2>When you're ready to actually build something.</h2>
        <p class="dek">From a focused strategy session to a full custom AI build — I work with you directly, at every stage.</p>
      </div>
      <div class="services-ladder">
        <div class="service-row">
          <div class="service-step">Step 2</div>
          <div class="service-content">
            <div class="service-head">
              <h3>Strategy Session</h3>
              <span class="service-price">$250 – $500</span>
            </div>
            <p>A focused 90-minute working session where we map out your AI roadmap — what to build, what to buy off the shelf, and what to skip entirely. You leave with a prioritized action plan.</p>
          </div>
          <a href="/ai-audit" class="service-cta-btn">Book a session →</a>
        </div>

        <div class="service-row">
          <div class="service-step">Step 3</div>
          <div class="service-content">
            <div class="service-head">
              <h3>AI-Ready Website &amp; SEO Overhaul</h3>
              <span class="service-price">From $1,200</span>
            </div>
            <p>Your website rebuilt to rank in AI search (ChatGPT, Perplexity, Google AI Overviews) — not just Google. Structured data, AEO content, and local AI citations all included.</p>
          </div>
          <a href="/contact" class="service-cta-btn">Get a quote →</a>
        </div>

        <div class="service-row">
          <div class="service-step">Step 4</div>
          <div class="service-content">
            <div class="service-head">
              <h3>Voice Agent — AI Receptionist</h3>
              <span class="service-price">From $297/mo</span>
            </div>
            <p>An AI that answers your phone 24/7 — qualifying leads, booking appointments, handling FAQs. Sounds human. Deployed in 5 business days.</p>
          </div>
          <a href="/how-it-works" class="service-cta-btn">See how it works →</a>
        </div>

        <div class="service-row">
          <div class="service-step">Step 5</div>
          <div class="service-content">
            <div class="service-head">
              <h3>Custom AI Builds</h3>
              <span class="service-price">Quote-based</span>
            </div>
            <p>Bespoke AI built around your data, your workflows, and your team's way of working. From internal knowledge bases to multi-step automations that replace hours of manual work.</p>
          </div>
          <a href="/contact" class="service-cta-btn">Let's talk →</a>
        </div>
      </div>
    </div>
  </section>

  <!-- TESTIMONIAL — walnut wood section -->
  <section class="testi">
    <div class="wood-overlay" aria-hidden="true"></div>
    <div class="testi-inner">
      <svg width="32" height="24" viewBox="0 0 32 24" fill="none" aria-hidden="true" style="margin-bottom:24px;opacity:.4">
        <path d="M0 24 C0 14 4 6 14 0L16 4 C10 8 8 12 8 16v8H0Z M18 24 C18 14 22 6 32 0L34 4 C28 8 26 12 26 16v8H18Z" fill="#C99356"/>
      </svg>
      <blockquote>
        "Mark set up our voice agent in four days. It books as many appointments in a weekend
        as my front desk used to handle in a week — and it's cheaper than one hour of my time."
      </blockquote>
      <div class="cite-name">Dr. Priya Ramanathan</div>
      <div class="cite-role">Owner · Harbor Dental · Boulder, CO</div>
    </div>
  </section>

  <!-- ABOUT MARK — light section with wood accent -->
  <section class="section section-bone">
    <div class="wrap about-grid">
      <div class="about-wood-panel" aria-hidden="true">
        <div class="about-wood-inner">
          <div class="about-caption">
            <div class="about-caption-name">Mark Bloomfield</div>
            <div class="about-caption-title">Your Personal AI Guy</div>
          </div>
        </div>
      </div>
      <div class="about-text">
        <span class="eyebrow">Why work with me</span>
        <h2>I'm not a consultant who learned AI last year.</h2>
        <p>
          I spent years as a composites research engineer and sustainability consultant
          before the AI wave hit. When I saw what it could do for small businesses — not
          the hype, the actual practical tools — I built Averde to make it accessible.
        </p>
        <p>
          Every client works directly with me. I figure out what you actually need,
          skip the things you don't, and build or deploy it fast. Based in Boulder, CO.
          Working with businesses everywhere.
        </p>
        <a href="/about" class="btn btn-primary" style="margin-top:8px">Meet Mark →</a>
      </div>
    </div>
  </section>

  <!-- FINAL CTA -->
  <section class="final-cta">
    <div class="wrap">
      <span class="eyebrow" style="justify-content:center;margin-bottom:20px">The simplest place to start</span>
      <h2>Not sure where AI fits?<br/>Start with the free audit.</h2>
      <p class="dek">
        30 minutes. I'll map out exactly where AI can help your specific business,
        what it costs, and what to realistically expect. No jargon. No pressure.
      </p>
      <a href="/ai-audit" class="btn btn-primary btn-lg">Book your free AI audit</a>
      <div class="micro">No commitment · No credit card · Just clarity</div>
    </div>
  </section>

</BaseLayout>

<style>
  /* ---------------------------------------------------------------
     Homepage — Mark Bloomfield personal brand
     Wood-forward design with clear funnel
  --------------------------------------------------------------- */

  .wrap { max-width: 1180px; margin: 0 auto; padding: 0 40px; }
  @media (max-width: 720px) { .wrap { padding: 0 24px; } }

  /* ---- SVG wood-grain data URI (reused across sections) ---- */
  /* Low X / high Y turbulence = horizontal wood grain lines */
  :root {
    --wood-grain: url("data:image/svg+xml;utf8,<svg xmlns='http://www.w3.org/2000/svg' width='500' height='500'><filter id='wg'><feTurbulence type='turbulence' baseFrequency='0.018 0.72' numOctaves='4' seed='12' stitchTiles='stitch'/><feColorMatrix type='matrix' values='0 0 0 0 0.55 0 0 0 0 0.33 0 0 0 0 0.12 0 0 0 1 0'/></filter><rect width='500' height='500' filter='url(%23wg)'/></svg>");
  }

  /* ---- EYEBROW ---- */
  .eyebrow {
    font-family: 'Inter Tight', system-ui, sans-serif;
    font-size: 11px; font-weight: 700;
    letter-spacing: 0.18em; text-transform: uppercase;
    color: var(--rust);
    display: inline-flex; align-items: center; gap: 10px;
  }
  .eyebrow::before { content: ""; width: 18px; height: 1px; background: currentColor; }
  .eyebrow-light { color: var(--honey-100); }
  .eyebrow-light::before { background: var(--honey-100); }

  /* ---- BUTTONS ---- */
  .btn {
    display: inline-flex; align-items: center;
    padding: 13px 22px; border-radius: 5px;
    font-family: 'Inter Tight', sans-serif;
    font-size: 14px; font-weight: 600; letter-spacing: 0.01em;
    white-space: nowrap; text-decoration: none;
    border: 1.5px solid transparent; cursor: pointer;
    transition: all 180ms ease;
  }
  .btn-primary { background: var(--walnut-700); color: var(--paper); }
  .btn-primary:hover { background: var(--charcoal); }
  .btn-ghost { background: transparent; color: var(--ink); border-color: rgba(31,26,18,.3); }
  .btn-ghost:hover { background: rgba(31,26,18,.05); }
  .btn-lg { padding: 16px 30px; font-size: 15px; }

  /* ---- HERO ---- */
  .hero {
    padding: 0 0 80px;
    background: var(--paper);
    position: relative; overflow: hidden;
  }
  /* Visible wood-plank strip across top of hero */
  .wood-strip {
    height: 180px;
    background-color: var(--walnut-500);
    background-image: var(--wood-grain);
    background-size: 500px;
    background-blend-mode: multiply;
    opacity: 0.9;
    margin-bottom: 0;
    position: relative;
  }
  .wood-strip::after {
    content: "";
    position: absolute; bottom: -1px; left: 0; right: 0; height: 40px;
    background: linear-gradient(to bottom, transparent, var(--paper));
  }
  .hero-grid {
    display: grid; grid-template-columns: 1fr 1fr;
    gap: 64px; align-items: start;
    margin-top: -80px; position: relative; z-index: 2;
    padding-top: 0;
  }
  .hero-text { padding-top: 16px; }
  .tag {
    display: inline-block;
    background: var(--aged-cream);
    border: 1px solid var(--driftwood);
    border-radius: 3px;
    padding: 4px 10px;
    font-family: 'Inter Tight', sans-serif;
    font-size: 11px; font-weight: 600;
    letter-spacing: 0.08em; text-transform: uppercase;
    color: var(--smoke);
    margin-bottom: 20px;
  }
  .hero h1 {
    font-family: 'Fraunces', Georgia, serif;
    font-size: clamp(3.5rem, 7vw, 6rem);
    font-weight: 300; letter-spacing: -0.03em; line-height: 0.95;
    color: var(--ink); margin: 0 0 24px; text-wrap: balance;
  }
  .hero h1 em { font-style: italic; color: var(--rust); display: block; }
  .hero-sub {
    font-family: 'Source Serif 4', Georgia, serif;
    font-size: 18px; line-height: 1.65; color: var(--ink-700);
    max-width: 48ch; margin: 0 0 32px;
  }
  .hero-ctas { display: flex; gap: 10px; margin-bottom: 24px; flex-wrap: wrap; }
  .hero-trust {
    font-family: 'Inter Tight', sans-serif;
    font-size: 11px; letter-spacing: 0.06em; text-transform: uppercase;
    color: var(--smoke); display: flex; gap: 8px; flex-wrap: wrap; align-items: center;
  }
  .hero-trust .dot { color: var(--driftwood); }

  /* Hero card — the photo placeholder with wood frame */
  .hero-card-wrap { position: relative; padding-top: 24px; }
  .hero-card {
    border-radius: 8px; overflow: hidden;
    border: 1px solid var(--driftwood);
    box-shadow: 0 20px 48px rgba(31,26,18,.2), 0 4px 8px rgba(31,26,18,.1);
  }
  .hero-card-img {
    aspect-ratio: 4/3;
    background-color: var(--walnut-700);
    background-image: var(--wood-grain);
    background-size: 500px;
    background-blend-mode: multiply;
    position: relative;
  }
  .hero-card-img::after {
    content: "";
    position: absolute; inset: 0;
    background: linear-gradient(160deg, rgba(201,147,86,.25) 0%, transparent 50%, rgba(31,26,18,.5) 100%);
  }
  .hero-card-caption {
    position: absolute; bottom: 16px; left: 16px;
    background: var(--paper); border-radius: 4px;
    padding: 8px 12px;
    box-shadow: 0 4px 12px rgba(31,26,18,.15); z-index: 2;
  }
  .caption-name {
    font-family: 'Fraunces', serif; font-size: 14px; font-weight: 600; color: var(--ink);
  }
  .caption-role {
    font-family: 'Inter Tight', sans-serif; font-size: 10px;
    letter-spacing: 0.06em; color: var(--smoke); margin-top: 2px;
  }
  .hero-card-body {
    background: var(--aged-cream);
    border-top: 1px solid var(--driftwood);
    padding: 18px 22px;
  }
  .hero-card-tag {
    font-family: 'Inter Tight', sans-serif; font-size: 10px;
    font-weight: 700; letter-spacing: 0.14em; text-transform: uppercase;
    color: var(--rust); margin-bottom: 10px;
  }
  .hero-card-list {
    list-style: none; padding: 0; margin: 0;
    display: flex; flex-direction: column; gap: 6px;
  }
  .hero-card-list li {
    font-family: 'Source Serif 4', serif; font-size: 14px; color: var(--ink-700);
    padding-left: 14px; position: relative;
  }
  .hero-card-list li::before {
    content: "·"; position: absolute; left: 2px;
    color: var(--rust); font-weight: 800; font-size: 16px; line-height: 1.1;
  }
  .hero-badge {
    position: absolute; top: 0; right: -12px;
    width: 96px; height: 96px; border-radius: 999px;
    background: var(--honey-300); color: var(--walnut-700);
    display: flex; flex-direction: column;
    align-items: center; justify-content: center;
    box-shadow: 0 4px 12px rgba(31,26,18,.2);
    transform: rotate(-8deg); text-align: center;
    border: 1px solid var(--honey-500);
  }
  .hero-badge-num { font-family: 'Fraunces', serif; font-size: 30px; font-weight: 500; line-height: 1; }
  .hero-badge-lbl {
    font-family: 'Inter Tight', sans-serif; font-size: 8px;
    text-transform: uppercase; letter-spacing: .12em; font-weight: 700;
    margin-top: 3px; max-width: 64px; line-height: 1.3;
  }
  @media (max-width: 860px) {
    .hero-grid { grid-template-columns: 1fr; gap: 40px; margin-top: -40px; }
    .wood-strip { height: 120px; }
  }

  /* ---- SECTIONS ---- */
  .section { padding: 96px 0; }
  .section-bone { background: var(--bone); }
  .section-head { margin-bottom: 52px; max-width: 760px; }
  .section-head h2, h2 {
    font-family: 'Fraunces', serif;
    font-size: clamp(2rem, 3.5vw, 2.75rem);
    font-weight: 500; letter-spacing: -0.02em; line-height: 1.1;
    color: var(--ink); margin: 16px 0 0; text-wrap: balance;
  }
  .dek {
    font-family: 'Source Serif 4', serif;
    font-size: 18px; color: var(--ink-700);
    margin: 14px 0 0; max-width: 54ch; line-height: 1.6;
  }

  /* ---- WOOD DARK SECTION (tools) ---- */
  .wood-dark {
    background-color: var(--walnut-700);
    background-image: var(--wood-grain);
    background-size: 500px;
    background-blend-mode: multiply;
    position: relative;
  }
  .section-head-split {
    display: grid; grid-template-columns: 1fr 1fr;
    gap: 48px; align-items: end; margin-bottom: 52px;
  }
  .section-head-split h2.light {
    font-family: 'Fraunces', serif;
    font-size: clamp(2rem, 3.5vw, 2.75rem);
    font-weight: 500; letter-spacing: -0.02em; line-height: 1.1;
    color: var(--paper); margin: 16px 0 0; text-wrap: balance;
  }
  .dek-light {
    font-family: 'Source Serif 4', serif;
    font-size: 17px; color: rgba(244,236,219,.72);
    line-height: 1.65; max-width: 46ch;
    margin: 0; align-self: end;
  }
  @media (max-width: 720px) { .section-head-split { grid-template-columns: 1fr; } }

  .tools-grid {
    display: grid; grid-template-columns: repeat(3, 1fr); gap: 16px;
  }
  .tool-card {
    display: flex; flex-direction: column;
    background: rgba(244,236,219,.07);
    border: 1px solid rgba(244,236,219,.15);
    border-radius: 8px;
    padding: 28px 26px 24px;
    text-decoration: none; color: var(--paper);
    transition: background 200ms ease, border-color 200ms ease;
  }
  .tool-card:hover {
    background: rgba(244,236,219,.12);
    border-color: rgba(201,147,86,.5);
  }
  .tool-icon {
    width: 44px; height: 44px; border-radius: 8px;
    background: rgba(201,147,86,.15);
