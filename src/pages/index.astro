---
import BaseLayout from '../layouts/BaseLayout.astro';
---

<BaseLayout
  title="AI Voice Agents for Small Business | Averde AI | Boulder, CO"
  description="Averde AI builds AI voice agents that answer your phone 24/7 — booking appointments, qualifying leads, and handling calls for dental, HVAC, and real estate businesses."
  isHome={true}
>

  <!-- HERO -->
  <section class="relative bg-green-deep overflow-hidden">
    <!-- Animated waveform background -->
    <div class="absolute inset-0 flex items-center justify-center opacity-5 pointer-events-none" aria-hidden="true">
      <div class="flex items-end gap-2">
        {Array.from({length: 32}).map((_, i) => {
          const heights = [20,35,55,40,70,50,30,60,45,25,65,38,72,42,28,58,34,68,46,22,54,36,66,48,26,62,44,32,52,38,70,30];
          return (
            <div
              class="wave-bar bg-green-sage rounded-full"
              style={`width: 6px; height: ${heights[i % heights.length]}px;`}
            />
          );
        })}
      </div>
    </div>

    <div class="relative max-w-6xl mx-auto px-4 sm:px-6 py-24 md:py-32">
      <div class="max-w-3xl">
        <div class="inline-flex items-center gap-2 bg-green-mid/50 text-sand text-xs font-semibold px-3 py-1.5 rounded-full mb-6">
          <span class="w-1.5 h-1.5 bg-sand rounded-full animate-pulse"></span>
          AI Voice Agents for Small Business
        </div>
        <h1 class="font-jakarta text-5xl md:text-6xl lg:text-7xl font-extrabold text-white-warm leading-[1.05] tracking-tight mb-6">
          Never Miss<br />Another Call
        </h1>
        <p class="text-lg md:text-xl text-cream/80 leading-relaxed mb-8 max-w-2xl">
          AI voice agents that answer your phone 24/7 — qualifying leads, booking appointments,
          and handling FAQs automatically. Built for small businesses that can't afford to miss a customer.
        </p>
        <div class="flex flex-col sm:flex-row gap-3">
          <a
            href="/ai-audit"
            class="inline-flex items-center justify-center bg-sand text-green-deep font-semibold px-6 py-3.5 rounded-xl hover:bg-sand/90 transition-colors text-base"
          >
            Get My Free Missed Call Audit
          </a>
          <a
            href="/how-it-works"
            class="inline-flex items-center justify-center border border-cream/30 text-cream font-medium px-6 py-3.5 rounded-xl hover:bg-white/5 transition-colors text-base"
          >
            See How It Works →
          </a>
        </div>
        <p class="mt-5 text-xs text-cream/40">
          Live in 5 business days &nbsp;·&nbsp; 30-day money-back guarantee &nbsp;·&nbsp; Boulder, CO
        </p>
      </div>
    </div>
  </section>

  <!-- PAIN STATS -->
  <section class="bg-cream py-20">
    <div class="max-w-6xl mx-auto px-4 sm:px-6">
      <div class="max-w-2xl mb-12">
        <h2 class="font-jakarta text-3xl md:text-4xl font-bold text-green-deep leading-tight mb-4">
          Every Missed Call Is Revenue Walking Out the Door
        </h2>
        <p class="text-muted text-lg">
          Most small businesses don't realize how much they're losing — until they see the numbers.
        </p>
      </div>
      <div class="grid grid-cols-1 md:grid-cols-3 gap-6">
        {[
          { stat: '62%', label: 'of calls to small businesses go unanswered' },
          { stat: '$200–$500', label: 'average value of a single missed service appointment' },
          { stat: '80%', label: 'of callers who can\'t reach you will call a competitor instead' },
        ].map(item => (
          <div class="bg-white-warm rounded-2xl p-7 border-l-4 border-green-sage">
            <p class="font-jakarta text-4xl font-extrabold text-green-deep mb-2">{item.stat}</p>
            <p class="text-muted text-base leading-snug">{item.label}</p>
          </div>
        ))}
      </div>
    </div>
  </section>

  <!-- SOLUTION -->
  <section class="bg-white-warm py-20">
    <div class="max-w-6xl mx-auto px-4 sm:px-6">
      <div class="text-center max-w-2xl mx-auto mb-14">
        <h2 class="font-jakarta text-3xl md:text-4xl font-bold text-green-deep mb-4">
          Meet Your AI Receptionist
        </h2>
        <p class="text-muted text-lg">Sounds human. Works 24/7. Books appointments automatically.</p>
      </div>
      <div class="grid grid-cols-1 md:grid-cols-3 gap-8">
        {[
          {
            icon: '🌙',
            title: 'Always On',
            body: 'Answers every call, day or night, holidays included. No hold music. No voicemail. No missed opportunities.',
          },
          {
            icon: '📅',
            title: 'Books Appointments',
            body: 'Syncs with your calendar and books appointments directly during the call. No back-and-forth, no double-bookings.',
          },
          {
            icon: '🗣️',
            title: 'Sounds Human',
            body: 'Natural conversation powered by the latest AI. Callers get a warm, helpful experience every single time.',
          },
        ].map(card => (
          <div class="bg-cream rounded-2xl p-8 text-center">
            <div class="text-4xl mb-4">{card.icon}</div>
            <h3 class="font-jakarta text-xl font-bold text-green-deep mb-3">{card.title}</h3>
            <p class="text-muted leading-relaxed">{card.body}</p>
          </div>
        ))}
      </div>
    </div>
  </section>

  <!-- INDUSTRIES -->
  <section class="bg-cream py-20">
    <div class="max-w-6xl mx-auto px-4 sm:px-6">
      <div class="max-w-2xl mb-12">
        <h2 class="font-jakarta text-3xl md:text-4xl font-bold text-green-deep mb-4">
          Built for Your Industry
        </h2>
        <p class="text-muted text-lg">Every business is different. Your AI agent is built specifically for how your industry works.</p>
      </div>
      <div class="grid grid-cols-1 md:grid-cols-3 gap-6">
        {[
          { icon: '🦷', title: 'Dental Practices', desc: 'Never lose a patient to voicemail again. Book appointments, handle insurance questions, and manage recalls 24/7.', href: '/dental' },
          { icon: '🔧', title: 'HVAC & Contractors', desc: 'Emergency calls answered. Jobs booked. Your AI agent triages urgency and dispatches correctly every time.', href: '/hvac' },
          { icon: '🏠', title: 'Real Estate Agents', desc: 'Be the first to respond — every single time. Qualify leads, schedule showings, and capture buyers before competitors do.', href: '/real-estate' },
        ].map(card => (
          <a
            href={card.href}
            class="group block bg-green-deep rounded-2xl p-8 text-cream hover:bg-green-mid transition-colors"
          >
            <div class="text-4xl mb-5">{card.icon}</div>
            <h3 class="font-jakarta text-xl font-bold mb-3">{card.title}</h3>
            <p class="text-cream/70 leading-relaxed mb-5 text-sm">{card.desc}</p>
            <span class="text-sand text-sm font-semibold group-hover:gap-2 flex items-center gap-1.5 transition-all">
              Learn more <span class="group-hover:translate-x-1 transition-transform">→</span>
            </span>
          </a>
        ))}
      </div>
    </div>
  </section>

  <!-- HOW IT WORKS -->
  <section class="bg-white-warm py-20">
    <div class="max-w-6xl mx-auto px-4 sm:px-6">
      <div class="text-center max-w-2xl mx-auto mb-14">
        <h2 class="font-jakarta text-3xl md:text-4xl font-bold text-green-deep mb-4">
          Live in 5 Business Days
        </h2>
        <p class="text-muted text-lg">From first conversation to fully deployed agent — faster than you'd expect.</p>
      </div>
      <div class="grid grid-cols-1 md:grid-cols-3 gap-8">
        {[
          { num: '01', title: 'Free Missed Call Audit', body: 'We analyze your call data and show you exactly how much revenue you\'re losing — and what your ROI would look like.' },
          { num: '02', title: 'We Build Your Agent', body: 'Custom voice, your business knowledge, integrated with your calendar. We handle everything technical.' },
          { num: '03', title: 'Your Phone Gets Answered', body: 'Every call handled professionally and automatically, 24/7. You focus on the work. We handle the phone.' },
        ].map(step => (
          <div class="relative">
            <div class="text-6xl font-extrabold text-green-sage/20 font-jakarta mb-3 leading-none">{step.num}</div>
            <h3 class="font-jakarta text-xl font-bold text-green-deep mb-3">{step.title}</h3>
            <p class="text-muted leading-relaxed">{step.body}</p>
          </div>
        ))}
      </div>
      <div class="mt-12 text-center">
        <a href="/how-it-works" class="text-green-mid font-semibold hover:text-green-deep transition-colors">
          See the full process →
        </a>
      </div>
    </div>
  </section>

  <!-- PRICING TEASER -->
  <section class="bg-green-mid py-16">
    <div class="max-w-6xl mx-auto px-4 sm:px-6 text-center">
      <h2 class="font-jakarta text-3xl md:text-4xl font-bold text-cream mb-4">
        Simple, Transparent Pricing
      </h2>
      <p class="text-cream/70 text-lg mb-8">
        Plans start at $297/month. Setup included. 30-day money-back guarantee.
      </p>
      <a
        href="/pricing"
        class="inline-flex items-center bg-sand text-green-deep font-semibold px-6 py-3.5 rounded-xl hover:bg-sand/90 transition-colors"
      >
        See All Plans →
      </a>
    </div>
  </section>

  <!-- FINAL CTA -->
  <section class="bg-green-deep py-24">
    <div class="max-w-3xl mx-auto px-4 sm:px-6 text-center">
      <h2 class="font-jakarta text-3xl md:text-4xl font-bold text-white-warm mb-5">
        Ready to Find Out How Much You're Losing?
      </h2>
      <p class="text-cream/70 text-lg mb-8">
        The Missed Call Audit is free. In 30 minutes, you'll know exactly what AI can do for your business.
      </p>
      <a
        href="/ai-audit"
        class="inline-flex items-center bg-sand text-green-deep font-bold px-8 py-4 rounded-xl text-base hover:bg-sand/90 transition-colors"
      >
        Book Your Free Audit
      </a>
      <p class="mt-4 text-cream/40 text-sm">No commitment. No credit card. Just clarity.</p>
    </div>
  </section>

</BaseLayout>
