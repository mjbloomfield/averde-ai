---
import BaseLayout from '../layouts/BaseLayout.astro';
import { createReader } from '@keystatic/core/reader';
import keystaticConfig from '../../keystatic.config';

const reader = createReader(process.cwd(), keystaticConfig);
const pricing = await reader.singletons.pricing.read();

const heroHeadline = pricing?.heroHeadline ?? 'Simple, honest pricing.';
const heroDek = pricing?.heroDek ?? 'Start with the free audit. Step up when you need more.';
const plans = pricing?.plans ?? [];
---

<BaseLayout
  title="Pricing — AI-Ready Websites, Strategy Sessions & Custom AI | Averde AI"
  description="Transparent pricing for getting your business found in ChatGPT, Perplexity, and Google AI Overviews. AI-Ready Websites, strategy sessions, voice agents, and custom AI builds."
>

  <!-- HERO -->
  <section class="bg-green-deep py-20 text-center">
    <div class="max-w-3xl mx-auto px-4 sm:px-6">
      <h1 class="text-5xl md:text-6xl font-extrabold text-white-warm leading-tight mb-5">
        {heroHeadline}
      </h1>
      <p class="text-cream/70 text-xl">{heroDek}</p>
    </div>
  </section>

  <!-- PRICING CARDS -->
  <section class="bg-cream py-20">
    <div class="max-w-6xl mx-auto px-4 sm:px-6">
      <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-4 gap-6 items-stretch">
        {plans.map((plan: { name: string; price?: string; description: string; ctaLabel: string; featured?: boolean; features: string[] }) => {
          const displayPrice = plan.price?.trim() || 'Contact for pricing';
          return (
            <div class={`rounded-3xl p-7 flex flex-col h-full ${plan.featured ? 'bg-green-deep text-cream ring-2 ring-sand' : 'bg-white-warm'}`}>
              {plan.featured && (
                <div class="inline-flex self-start items-center bg-sand text-green-deep text-xs font-bold px-3 py-1 rounded-full mb-4 uppercase tracking-wide">
                  Recommended
                </div>
              )}
              <h2 class={`text-2xl font-bold mb-2 ${plan.featured ? 'text-cream' : 'text-green-deep'}`}>{plan.name}</h2>
              <p class={`text-sm mb-5 ${plan.featured ? 'text-cream/70' : 'text-muted'}`}>{plan.description}</p>
              <div class="mb-6">
                <span class={`text-3xl font-extrabold ${plan.featured ? 'text-cream' : 'text-green-deep'}`}>{displayPrice}</span>
              </div>
              <ul class="space-y-2.5 mb-8 flex-1">
                {plan.features.map(f => (
                  <li class="flex items-start gap-2.5">
                    <svg width="18" height="18" viewBox="0 0 18 18" fill="none" class="mt-0.5 flex-shrink-0">
                      <circle cx="9" cy="9" r="9" fill="#C99356" fill-opacity="0.2"/>
                      <path d="M5 9l3 3 5-5" stroke="#C99356" stroke-width="1.6" stroke-linecap="round" stroke-linejoin="round"/>
                    </svg>
                    <span class={`text-sm ${plan.featured ? 'text-cream/85' : 'text-dark'}`}>{f}</span>
                  </li>
                ))}
              </ul>
              <a
                href="/ai-audit"
                class={`block text-center font-semibold py-3 rounded-xl transition-colors text-sm ${
                  plan.featured
                    ? 'bg-sand text-green-deep hover:bg-sand/90'
                    : 'bg-green-deep text-cream hover:bg-green-mid'
                }`}
              >
                {plan.ctaLabel}
              </a>
            </div>
          );
        })}
      </div>

      <!-- Reassurance row -->
      <div class="mt-10 text-center space-y-2">
        <p class="text-muted text-sm">
          ✓ Every engagement starts with a free audit  ·  ✓ No long-term contracts  ·  ✓ Direct work with Mark
        </p>
      </div>
    </div>
  </section>

  <!-- ADD-ON: AUDIT -->
  <section class="bg-white-warm py-16">
    <div class="max-w-3xl mx-auto px-4 sm:px-6">
      <div class="bg-sand/20 border border-sand/40 rounded-3xl p-10 text-center">
        <p class="text-sand font-bold text-sm uppercase tracking-wide mb-3">Start here</p>
        <h2 class="text-2xl md:text-3xl font-bold text-green-deep mb-4">
          Free AI Readiness Audit
        </h2>
        <p class="text-muted mb-6 max-w-lg mx-auto">
          Six questions, three minutes. Get a personalized report with your top three highest-impact AI
          opportunities — ranked by what'll move the needle for your business.
        </p>
        <a
          href="/ai-audit"
          class="inline-flex items-center bg-green-deep text-cream font-semibold px-6 py-3.5 rounded-xl hover:bg-green-mid transition-colors"
        >
          Run my free audit →
        </a>
      </div>
    </div>
  </section>

  <!-- FAQ MINI -->
  <section class="bg-cream py-16">
    <div class="max-w-3xl mx-auto px-4 sm:px-6 text-center">
      <p class="text-muted">Not sure which plan fits? <a href="/contact" class="text-green-mid font-semibold hover:text-green-deep">Send a message</a> or <a href="/ai-audit" class="text-green-mid font-semibold hover:text-green-deep">run the audit</a> — that's the fastest way to figure out what's actually right for you.</p>
    </div>
  </section>

</BaseLayout>
