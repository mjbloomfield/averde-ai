---
import BaseLayout from '../layouts/BaseLayout.astro';
import { createReader } from '@keystatic/core/reader';
import keystaticConfig from '../../keystatic.config';

// Read the About singleton straight from the Keystatic content file
// (src/content/pages/about.yaml). This is what makes CMS edits actually
// render — the page reads the file Keystatic writes.
const reader = createReader(process.cwd(), keystaticConfig);
const about = await reader.singletons.about.read();

// Icons for the values cards — keyed by position, since the values text is
// CMS-driven but the artwork isn't.
const valueIcons = [
  `<svg width="28" height="28" viewBox="0 0 28 28" fill="none"><circle cx="12" cy="12" r="8" stroke="#C99356" stroke-width="1.8"/><path d="M18 18l4 4" stroke="#C99356" stroke-width="1.8" stroke-linecap="round"/></svg>`,
  `<svg width="28" height="28" viewBox="0 0 28 28" fill="none"><path d="M14 4v4M14 20v4M4 14h4M20 14h4M7 7l2.8 2.8M18.2 18.2l2.8 2.8M7 21l2.8-2.8M18.2 9.8l2.8-2.8" stroke="#C99356" stroke-width="1.8" stroke-linecap="round"/></svg>`,
  `<svg width="28" height="28" viewBox="0 0 28 28" fill="none"><path d="M6 20V14M11 20V10M16 20V6M21 20V12" stroke="#C99356" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round"/></svg>`,
];

const bioParagraphs = [about.bioIntro, about.bioBackground, about.bioApproach].filter(Boolean);
---

<BaseLayout
  title="About Mark Bloomfield | Your Personal AI Guy | Boulder, CO"
  description="Engineer, founder, and the person small business owners call when they want to figure out AI without the jargon. AI-Ready Websites and AI consulting from Boulder, CO."
>

  <!-- HERO -->
  <section class="wood-beam bg-green-deep py-20">
    <div class="max-w-4xl mx-auto px-4 sm:px-6 text-center">
      <h1 class="text-5xl md:text-6xl font-extrabold text-white-warm leading-tight mb-5">
        {about.heroHeadline}
      </h1>
      <p class="text-cream/70 text-xl max-w-2xl mx-auto">
        {about.heroDek}
      </p>
    </div>
  </section>

  <!-- MARK -->
  <section class="bg-cream topo-map topo-flagstaff py-20">
    <div class="max-w-5xl mx-auto px-4 sm:px-6">
      <div class="grid grid-cols-1 md:grid-cols-2 gap-14 items-center">
        <div>
          <img
            src="/images/mark-headshot.jpg"
            alt="Mark Bloomfield"
            width="480"
            height="600"
            loading="lazy"
            class="rounded-3xl w-full object-cover shadow-lg"
          />
        </div>
        <div>
          <p class="text-sand font-semibold text-sm uppercase tracking-widest mb-3">Founder · Your Personal AI Guy</p>
          <h2 class="text-3xl md:text-4xl font-bold text-green-deep mb-5">Mark Bloomfield</h2>
          <div class="space-y-4 text-muted leading-relaxed">
            {bioParagraphs.map(p => <p>{p}</p>)}
          </div>
          <div class="mt-6 pt-6 border-t border-green-sage/20">
            <p class="text-green-deep font-medium italic">
              "I won't build something for you that I wouldn't build for myself. If it doesn't make sense for your business, I'll tell you that — that's the whole job."
            </p>
          </div>
        </div>
      </div>
    </div>
  </section>

  <!-- OLIVE -->
  <section class="bg-white-warm py-20">
    <div class="max-w-5xl mx-auto px-4 sm:px-6">
      <div class="grid grid-cols-1 md:grid-cols-2 gap-14 items-center">
        <div class="order-2 md:order-1">
          <p class="text-sand font-semibold text-sm uppercase tracking-widest mb-3">Chief Canine Officer</p>
          <h2 class="text-3xl md:text-4xl font-bold text-green-deep mb-5">Olive</h2>
          <div class="space-y-4 text-muted leading-relaxed">
            <p>
              Every business needs a CCO. Olive brings unwavering enthusiasm, exceptional listening skills, and zero tolerance for mediocrity — especially when it comes to treats.
            </p>
            <p>
              She supervises all quality control, attends every strategy session (usually from the floor), and reminds me that the best businesses are built on loyalty, showing up every day, and being genuinely happy to hear from customers.
            </p>
            <p>
              Olive's also a reminder of what this work is really about: giving small business owners back the time and peace of mind to spend on what matters most.
            </p>
          </div>
        </div>
        <div class="order-1 md:order-2">
          <img
            src="/images/olive.jpg"
            alt="Olive, Chief Canine Officer"
            width="480"
            height="600"
            loading="lazy"
            class="rounded-3xl w-full object-cover shadow-lg"
          />
        </div>
      </div>
    </div>
  </section>

  <!-- VALUES -->
  <section class="bg-cream py-20">
    <div class="max-w-6xl mx-auto px-4 sm:px-6">
      <h2 class="text-3xl md:text-4xl font-bold text-green-deep mb-12 text-center">What I Stand For</h2>
      <div class="grid grid-cols-1 md:grid-cols-3 gap-8">
        {about.values.map((v, i) => (
          <div class="bg-white-warm rounded-2xl p-8 text-center">
            <div class="flex justify-center mb-4" set:html={valueIcons[i % valueIcons.length]} />
            <h3 class="text-xl font-bold text-green-deep mb-3">{v.title}</h3>
            <p class="text-muted leading-relaxed">{v.description}</p>
          </div>
        ))}
      </div>
    </div>
  </section>

  <!-- CTA -->
  <section class="wood-beam bg-green-deep py-20 text-center">
    <div class="max-w-2xl mx-auto px-4 sm:px-6">
      <h2 class="text-3xl font-bold text-white-warm mb-5">Ready to Work Together?</h2>
      <p class="text-cream/70 mb-8">Start with the free AI Visibility Audit — three minutes, live checks on your real website, and a fix-it-yourself action plan.</p>
      <a href="/ai-audit" class="inline-flex items-center bg-sand text-green-deep font-bold px-8 py-4 rounded-xl hover:bg-sand/90 transition-colors">
        Run my free audit
      </a>
    </div>
  </section>

</BaseLayout>
