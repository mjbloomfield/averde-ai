---
import { getCollection } from 'astro:content';
import BaseLayout from '../../layouts/BaseLayout.astro';

export async function getStaticPaths() {
  const industries = await getCollection('industries');
  return industries
    .filter(ind => ind.data.published !== false)
    .map(ind => ({ params: { slug: ind.id } }));
}

const { slug } = Astro.params;
const all = await getCollection('industries');
const industry = all.find(i => i.id === slug);
if (!industry) return Astro.redirect('/');

const d = industry.data;
---

<BaseLayout title={d.seoTitle} description={d.seoDescription}>

  <!-- HERO -->
  <section class="bg-green-deep py-24">
    <div class="max-w-6xl mx-auto px-4 sm:px-6">
      <div class="max-w-3xl">
        <div class="inline-flex items-center gap-2 bg-green-mid/50 text-sand text-xs font-semibold px-3 py-1.5 rounded-full mb-6">
          {d.heroEyebrow}
        </div>
        <h1 class="text-5xl md:text-6xl font-extrabold text-white-warm leading-tight tracking-tight mb-6">
          {d.heroHeadline}
        </h1>
        <p class="text-cream/80 text-xl leading-relaxed mb-8">{d.heroDek}</p>
        <a href="/ai-audit" class="inline-flex items-center bg-sand text-green-deep font-semibold px-6 py-3.5 rounded-xl hover:bg-sand/90 transition-colors">
          {d.heroCta}
        </a>
      </div>
    </div>
  </section>

  <!-- PAIN POINTS -->
  <section class="bg-cream py-20">
    <div class="max-w-6xl mx-auto px-4 sm:px-6">
      <h2 class="text-3xl md:text-4xl font-bold text-green-deep mb-10">{d.painHeadline}</h2>
      <div class="grid grid-cols-1 md:grid-cols-2 gap-6">
        {d.painPoints.map(item => (
          <div class="bg-white-warm rounded-2xl p-7 border-l-2 border-sand/40">
            <p class="font-semibold text-green-deep mb-1">{item.pain}</p>
            <p class="text-muted text-sm">{item.result}</p>
          </div>
        ))}
      </div>
    </div>
  </section>

  <!-- SOLUTION / CAPABILITIES -->
  <section class="bg-white-warm py-20">
    <div class="max-w-6xl mx-auto px-4 sm:px-6">
      <h2 class="text-3xl md:text-4xl font-bold text-green-deep mb-4">{d.solutionHeadline}</h2>
      <p class="text-muted text-lg mb-10">{d.solutionDek}</p>
      <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-5">
        {d.capabilities.map(item => (
          <div class="flex items-start gap-3 bg-cream rounded-xl p-5">
            <span class="mt-0.5 shrink-0">
              <svg width="20" height="20" viewBox="0 0 20 20" fill="none">
                <circle cx="10" cy="10" r="10" fill="#C99356" fill-opacity="0.15"/>
                <path d="M6 10l3 3 5-5" stroke="#C99356" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round"/>
              </svg>
            </span>
            <p class="text-dark text-sm font-medium">{item}</p>
          </div>
        ))}
      </div>
    </div>
  </section>

  <!-- ROI -->
  <section class="bg-sand/20 py-16">
    <div class="max-w-4xl mx-auto px-4 sm:px-6">
      <div class="bg-sand rounded-3xl p-10 text-center">
        <p class="text-green-deep font-semibold mb-3 text-sm uppercase tracking-wide">The math</p>
        <h2 class="text-2xl md:text-3xl font-bold text-green-deep mb-5">{d.roiHeadline}</h2>
        {d.roiStats.length > 0 && (
          <div class="grid grid-cols-3 gap-4 mb-6">
            {d.roiStats.map(s => (
              <div>
                <p class="text-3xl font-extrabold text-green-deep">{s.stat}</p>
                <p class="text-sm text-green-mid">{s.label}</p>
              </div>
            ))}
          </div>
        )}
        <p class="text-green-deep font-medium mb-6 max-w-xl mx-auto">{d.roiBody}</p>
        <a href="/ai-audit" class="inline-flex items-center bg-green-deep text-cream font-semibold px-6 py-3 rounded-xl hover:bg-green-mid transition-colors">
          Calculate My ROI →
        </a>
      </div>
    </div>
  </section>

  <!-- BOTTOM CTA -->
  <section class="bg-green-deep py-20 text-center">
    <div class="max-w-2xl mx-auto px-4 sm:px-6">
      <h2 class="text-3xl font-bold text-white-warm mb-5">{d.ctaHeadline}</h2>
      <p class="text-cream/70 mb-8">{d.ctaDek}</p>
      <a href="/ai-audit" class="inline-flex items-center bg-sand text-green-deep font-bold px-8 py-4 rounded-xl hover:bg-sand/90 transition-colors">
        Book Free Audit
      </a>
      <p class="mt-4 text-cream/40 text-sm">No commitment. No credit card.</p>
    </div>
  </section>

</BaseLayout>
