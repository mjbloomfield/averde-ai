---
import BaseLayout from '../layouts/BaseLayout.astro';
import { createReader } from '@keystatic/core/reader';
import keystaticConfig from '../../keystatic.config';

const reader = createReader(process.cwd(), keystaticConfig);
const page = await reader.singletons.howItWorks.read();

const steps = page?.steps ?? [];
const included = page?.included ?? [];
const faqs = (page?.faqs ?? []).map(f => ({ q: f.q, a: f.a }));

// Icon set for the "what's included" cards — selected per-card in Keystatic.
const ICONS: Record<string, string> = {
  layers: `<svg width="24" height="24" viewBox="0 0 24 24" fill="none"><path d="M12 4l8 4-8 4-8-4 8-4zM4 12l8 4 8-4M4 16l8 4 8-4" stroke="#C99356" stroke-width="1.6" stroke-linecap="round" stroke-linejoin="round"/></svg>`,
  check: `<svg width="24" height="24" viewBox="0 0 24 24" fill="none"><circle cx="12" cy="12" r="9" stroke="#C99356" stroke-width="1.6"/><path d="M9 12l2 2 4-4" stroke="#C99356" stroke-width="1.6" stroke-linecap="round" stroke-linejoin="round"/></svg>`,
  compass: `<svg width="24" height="24" viewBox="0 0 24 24" fill="none"><path d="M12 2v4M12 18v4M2 12h4M18 12h4M5.6 5.6l2.8 2.8M15.6 15.6l2.8 2.8M5.6 18.4l2.8-2.8M15.6 8.4l2.8-2.8" stroke="#C99356" stroke-width="1.5" stroke-linecap="round"/><circle cx="12" cy="12" r="4" stroke="#C99356" stroke-width="1.5"/></svg>`,
  chart: `<svg width="24" height="24" viewBox="0 0 24 24" fill="none"><path d="M4 20V13M9 20V9M14 20V5M19 20V11" stroke="#C99356" stroke-width="1.6" stroke-linecap="round" stroke-linejoin="round"/></svg>`,
  doc: `<svg width="24" height="24" viewBox="0 0 24 24" fill="none"><rect x="3" y="4" width="18" height="14" rx="2" stroke="#C99356" stroke-width="1.6"/><path d="M3 8h18M7 12h10M7 15h6" stroke="#C99356" stroke-width="1.4" stroke-linecap="round"/></svg>`,
  person: `<svg width="24" height="24" viewBox="0 0 24 24" fill="none"><circle cx="12" cy="8" r="4" stroke="#C99356" stroke-width="1.6"/><path d="M4 20c0-4 3.6-7 8-7s8 3 8 7" stroke="#C99356" stroke-width="1.6" stroke-linecap="round"/></svg>`,
};
---

<BaseLayout
  title={page?.seoTitle ?? 'How It Works | Averde AI'}
  description={page?.seoDescription ?? ''}
  faqItems={faqs}
>

  <!-- HERO -->
  <section class="wood-alt bg-green-deep py-20">
    <div class="max-w-4xl mx-auto px-4 sm:px-6 text-center">
      <h1 class="text-5xl md:text-6xl font-extrabold text-cream leading-tight mb-5">
        {page?.heroHeadline}
      </h1>
      <p class="text-cream/70 text-xl">{page?.heroDek}</p>
    </div>
  </section>

  <!-- STEPS -->
  <section class="bg-cream topo-map topo-green py-20">
    <div class="max-w-4xl mx-auto px-4 sm:px-6">
      <div class="space-y-12">
        {steps.map(step => (
          <div class="pb-12 border-b border-green-sage/20 last:border-0 last:pb-0">
            <h3 class="text-2xl font-bold text-green-deep mb-3">{step.title}</h3>
            <p class="text-muted leading-relaxed">{step.body}</p>
            {step.ctaLabel && step.ctaHref && (
              <a href={step.ctaHref} class="inline-block mt-5 bg-green-deep text-cream font-semibold px-6 py-3 rounded-xl hover:bg-green-mid transition-colors">
                {step.ctaLabel}
              </a>
            )}
          </div>
        ))}
      </div>
    </div>
  </section>

  <!-- WHAT'S INCLUDED -->
  <section class="bg-cream topo-map topo-green py-20">
    <div class="max-w-6xl mx-auto px-4 sm:px-6">
      <h2 class="text-3xl md:text-4xl font-bold text-green-deep mb-10 text-center">{page?.includedHeadline}</h2>
      <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-5">
        {included.map(item => (
          <div class="bg-cream rounded-2xl p-6">
            <div class="mb-3" set:html={ICONS[item.icon] ?? ICONS.check} />
            <h3 class="font-bold text-green-deep mb-2">{item.title}</h3>
            <p class="text-muted text-sm">{item.body}</p>
          </div>
        ))}
      </div>
    </div>
  </section>

  <!-- FAQ -->
  <section class="bg-cream topo-map topo-green py-20">
    <div class="max-w-3xl mx-auto px-4 sm:px-6">
      <h2 class="text-3xl font-bold text-green-deep mb-10 text-center">{page?.faqHeadline}</h2>
      <div class="space-y-3">
        {faqs.map(faq => (
          <details class="bg-cream rounded-2xl px-6 group">
            <summary class="flex items-center justify-between py-5 font-semibold text-green-deep cursor-pointer">
              {faq.q}
              <span class="summary-arrow text-green-sage ml-4 flex-shrink-0">
                <svg width="18" height="18" viewBox="0 0 18 18" fill="none"><path d="M4 7l5 5 5-5" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round"/></svg>
              </span>
            </summary>
            <p class="text-muted leading-relaxed pb-5">{faq.a}</p>
          </details>
        ))}
      </div>
    </div>
  </section>

  <!-- CTA -->
  <section class="wood-alt bg-green-deep py-20 text-center">
    <div class="max-w-2xl mx-auto px-4 sm:px-6">
      <h2 class="text-3xl font-bold text-cream mb-5">{page?.ctaHeadline}</h2>
      <p class="text-cream/70 mb-8">{page?.ctaDek}</p>
      <a href="/ai-audit" class="inline-flex items-center bg-sand text-green-deep font-bold px-8 py-4 rounded-xl hover:bg-sand/90 transition-colors">
        {page?.ctaButton}
      </a>
    </div>
  </section>

</BaseLayout>
