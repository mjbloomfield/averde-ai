---
import SEOHead from '../components/SEOHead.astro';
import Nav from '../components/Nav.astro';
import Footer from '../components/Footer.astro';
import '../styles/global.css';

interface Props {
  title: string;
  description: string;
  canonical?: string;
  isHome?: boolean;
}
const { title, description, canonical, isHome = false } = Astro.props;
---

<!DOCTYPE html>
<html lang="en">
  <head>
    <SEOHead {title} {description} {canonical} {isHome} />
  </head>
  <body class="bg-cream min-h-screen flex flex-col">
    <Nav />
    <main class="flex-1">
      <slot />
    </main>
    <Footer />
  </body>
</html>
