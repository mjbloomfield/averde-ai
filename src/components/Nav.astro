---
import Logo from './Logo.astro';
const currentPath = Astro.url.pathname;
const isActive = (path: string) => currentPath === path || currentPath.startsWith(path + '/');
---

<header class="sticky top-0 z-50 bg-white-warm shadow-sm border-b border-green-sage/10">
  <nav class="max-w-6xl mx-auto px-4 sm:px-6 h-16 flex items-center justify-between">
    <!-- Logo -->
    <Logo size="md" />

    <!-- Desktop Nav -->
    <div class="hidden md:flex items-center gap-6">
      <a
        href="/how-it-works"
        class={`text-sm font-medium transition-colors hover:text-terracotta ${isActive('/how-it-works') ? 'text-dark border-b-2 border-terracotta pb-0.5' : 'text-dark'}`}
      >
        Services
      </a>

      <!-- Industries Dropdown -->
      <div class="relative" id="industries-menu">
        <button
          id="industries-btn"
          class="text-sm font-medium text-dark hover:text-terracotta flex items-center gap-1 transition-colors"
          aria-expanded="false"
          aria-haspopup="true"
        >
          Industries
          <svg width="12" height="12" viewBox="0 0 12 12" fill="none" class="mt-0.5" id="industries-chevron"><path d="M2 4l4 4 4-4" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"/></svg>
        </button>
        <div
          id="industries-dropdown"
          class="hidden absolute top-full left-0 pt-2 w-52 z-50"
        >
          <div class="bg-white-warm rounded-xl shadow-lg border border-muted/15 py-2">
            <a href="/dental" class="block px-4 py-2.5 text-sm text-dark hover:bg-cream hover:text-terracotta transition-colors">🦷 Dental Practices</a>
            <a href="/hvac" class="block px-4 py-2.5 text-sm text-dark hover:bg-cream hover:text-terracotta transition-colors">🔧 HVAC & Contractors</a>
            <a href="/real-estate" class="block px-4 py-2.5 text-sm text-dark hover:bg-cream hover:text-terracotta transition-colors">🏠 Real Estate</a>
          </div>
        </div>
      </div>

      <script>
        const btn = document.getElementById('industries-btn')!;
        const dropdown = document.getElementById('industries-dropdown')!;
        const chevron = document.getElementById('industries-chevron')!;

        btn.addEventListener('click', (e) => {
          e.stopPropagation();
          const isOpen = !dropdown.classList.contains('hidden');
          dropdown.classList.toggle('hidden', isOpen);
          btn.setAttribute('aria-expanded', String(!isOpen));
          chevron.style.transform = isOpen ? '' : 'rotate(180deg)';
        });

        document.addEventListener('click', () => {
          dropdown.classList.add('hidden');
          btn.setAttribute('aria-expanded', 'false');
          chevron.style.transform = '';
        });
      </script>

      <a
        href="/pricing"
        class={`text-sm font-medium transition-colors hover:text-terracotta ${isActive('/pricing') ? 'text-dark border-b-2 border-terracotta pb-0.5' : 'text-dark'}`}
      >
        Pricing
      </a>
      <a
        href="/about"
        class={`text-sm font-medium transition-colors hover:text-terracotta ${isActive('/about') ? 'text-dark border-b-2 border-terracotta pb-0.5' : 'text-dark'}`}
      >
        About
      </a>
      <a
        href="/blog"
        class={`text-sm font-medium transition-colors hover:text-terracotta ${isActive('/blog') ? 'text-dark border-b-2 border-terracotta pb-0.5' : 'text-dark'}`}
      >
        Blog
      </a>
    </div>

    <!-- CTA -->
    <div class="hidden md:block">
      <a
        href="/ai-audit"
        class="inline-flex items-center gap-1.5 bg-terracotta text-white-warm text-sm font-semibold px-4 py-2 rounded-lg hover:bg-terracotta/90 transition-colors"
      >
        Free AI Audit
      </a>
    </div>

    <!-- Mobile Toggle -->
    <label for="nav-toggle" class="md:hidden cursor-pointer p-2" aria-label="Toggle menu">
      <svg width="22" height="22" viewBox="0 0 22 22" fill="none">
        <path d="M3 6h16M3 11h16M3 16h16" stroke="#1B3A1F" stroke-width="2" stroke-linecap="round"/>
      </svg>
    </label>
  </nav>

  <!-- Mobile Menu -->
  <input type="checkbox" id="nav-toggle" class="hidden" />
  <div id="nav-menu" class="hidden flex-col md:hidden bg-white-warm border-t border-green-sage/10 px-4 pb-4 gap-1">
    <a href="/how-it-works" class="block py-2.5 text-sm font-medium text-dark hover:text-terracotta border-b border-cream">Services</a>
    <a href="/dental" class="block py-2.5 text-sm font-medium text-dark hover:text-terracotta border-b border-cream">🦷 Dental Practices</a>
    <a href="/hvac" class="block py-2.5 text-sm font-medium text-dark hover:text-terracotta border-b border-cream">🔧 HVAC & Contractors</a>
    <a href="/real-estate" class="block py-2.5 text-sm font-medium text-dark hover:text-terracotta border-b border-cream">🏠 Real Estate</a>
    <a href="/pricing" class="block py-2.5 text-sm font-medium text-dark hover:text-terracotta border-b border-cream">Pricing</a>
    <a href="/about" class="block py-2.5 text-sm font-medium text-dark hover:text-terracotta border-b border-cream">About</a>
    <a href="/blog" class="block py-2.5 text-sm font-medium text-dark hover:text-terracotta">Blog</a>
    <a href="/ai-audit" class="mt-3 block text-center bg-terracotta text-white-warm text-sm font-semibold px-4 py-3 rounded-lg">Free AI Audit</a>
  </div>
</header>
