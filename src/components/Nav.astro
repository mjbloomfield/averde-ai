---
import Logo from './Logo.astro';
const currentPath = Astro.url.pathname;
const isActive = (path: string) => currentPath === path || currentPath.startsWith(path + '/');
---

<header class="sticky top-0 z-50 bg-white-warm shadow-sm border-b border-green-sage/10">
  <nav class="max-w-6xl mx-auto px-4 sm:px-6 h-16 flex items-center justify-between">
    <!-- Logo -->
    <Logo size="md" />

    <!-- Desktop Nav -->
    <div class="hidden md:flex items-center gap-6">
      <a
        href="/how-it-works"
        class={`text-sm font-medium transition-colors hover:text-green-mid ${isActive('/how-it-works') ? 'text-green-deep border-b-2 border-green-sage pb-0.5' : 'text-dark'}`}
      >
        How It Works
      </a>

      <!-- Industries Dropdown -->
      <div class="nav-item relative">
        <button class="text-sm font-medium text-dark hover:text-green-mid flex items-center gap-1 transition-colors">
          Industries
          <svg width="12" height="12" viewBox="0 0 12 12" fill="none" class="mt-0.5"><path d="M2 4l4 4 4-4" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"/></svg>
        </button>
        <div class="nav-dropdown absolute top-full left-0 mt-2 w-48 bg-white-warm rounded-xl shadow-lg border border-green-sage/20 py-2 z-50">
          <a href="/dental" class="block px-4 py-2 text-sm text-dark hover:bg-cream hover:text-green-mid transition-colors">🦷 Dental Practices</a>
          <a href="/hvac" class="block px-4 py-2 text-sm text-dark hover:bg-cream hover:text-green-mid transition-colors">🔧 HVAC & Contractors</a>
          <a href="/real-estate" class="block px-4 py-2 text-sm text-dark hover:bg-cream hover:text-green-mid transition-colors">🏠 Real Estate</a>
        </div>
      </div>

      <a
        href="/pricing"
        class={`text-sm font-medium transition-colors hover:text-green-mid ${isActive('/pricing') ? 'text-green-deep border-b-2 border-green-sage pb-0.5' : 'text-dark'}`}
      >
        Pricing
      </a>
      <a
        href="/about"
        class={`text-sm font-medium transition-colors hover:text-green-mid ${isActive('/about') ? 'text-green-deep border-b-2 border-green-sage pb-0.5' : 'text-dark'}`}
      >
        About
      </a>
      <a
        href="/blog"
        class={`text-sm font-medium transition-colors hover:text-green-mid ${isActive('/blog') ? 'text-green-deep border-b-2 border-green-sage pb-0.5' : 'text-dark'}`}
      >
        Blog
      </a>
    </div>

    <!-- CTA -->
    <div class="hidden md:block">
      <a
        href="/ai-audit"
        class="inline-flex items-center gap-1.5 bg-sand text-green-deep text-sm font-semibold px-4 py-2 rounded-lg hover:bg-sand/90 transition-colors"
      >
        Book Free Audit
      </a>
    </div>

    <!-- Mobile Toggle -->
    <label for="nav-toggle" class="md:hidden cursor-pointer p-2" aria-label="Toggle menu">
      <svg width="22" height="22" viewBox="0 0 22 22" fill="none">
        <path d="M3 6h16M3 11h16M3 16h16" stroke="#1B3A1F" stroke-width="2" stroke-linecap="round"/>
      </svg>
    </label>
  </nav>

  <!-- Mobile Menu -->
  <input type="checkbox" id="nav-toggle" class="hidden" />
  <div id="nav-menu" class="hidden flex-col md:hidden bg-white-warm border-t border-green-sage/10 px-4 pb-4 gap-1">
    <a href="/how-it-works" class="block py-2.5 text-sm font-medium text-dark hover:text-green-mid border-b border-cream">How It Works</a>
    <a href="/dental" class="block py-2.5 text-sm font-medium text-dark hover:text-green-mid border-b border-cream">🦷 Dental Practices</a>
    <a href="/hvac" class="block py-2.5 text-sm font-medium text-dark hover:text-green-mid border-b border-cream">🔧 HVAC & Contractors</a>
    <a href="/real-estate" class="block py-2.5 text-sm font-medium text-dark hover:text-green-mid border-b border-cream">🏠 Real Estate</a>
    <a href="/pricing" class="block py-2.5 text-sm font-medium text-dark hover:text-green-mid border-b border-cream">Pricing</a>
    <a href="/about" class="block py-2.5 text-sm font-medium text-dark hover:text-green-mid border-b border-cream">About</a>
    <a href="/blog" class="block py-2.5 text-sm font-medium text-dark hover:text-green-mid">Blog</a>
    <a href="/ai-audit" class="mt-3 block text-center bg-sand text-green-deep text-sm font-semibold px-4 py-3 rounded-lg">Book Free Audit</a>
  </div>
</header>
