---
interface Props {
  title: string;
  description: string;
  canonical?: string;
  isHome?: boolean;
  faqItems?: { q: string; a: string }[];
}
const { title, description, canonical, isHome = false, faqItems } = Astro.props;
const url = canonical || Astro.url.href;
const site = 'https://averde.ai';

// Fail open: the live site indexes by default; only Vercel preview/branch URLs
// (VERCEL_ENV === 'preview') get noindexed so they don't compete as duplicate
// content. This can never accidentally noindex production.
const isProduction = process.env.VERCEL_ENV === 'production';
const noIndex = process.env.VERCEL_ENV === 'preview';

// GA4 measurement id (G-XXXX). Set PUBLIC_GA_ID in Vercel + .env to turn on.
const gaId = import.meta.env.PUBLIC_GA_ID;

// JSON-LD @graph — multiple cross-referenced entities. Modern best practice
// for AI search engines (ChatGPT, Perplexity, Google AI Overviews).
const graph: Record<string, unknown>[] = [
  {
    '@type': 'Organization',
    '@id': `${site}/#organization`,
    name: 'Averde AI',
    url: site,
    email: 'mark@averde.ai',
    description: "Averde AI helps small businesses get found in AI search (ChatGPT, Perplexity, Google AI Overviews) and deploy practical AI tools that fit their business.",
    founder: { '@id': `${site}/#mark` },
    address: {
      '@type': 'PostalAddress',
      addressLocality: 'Boulder',
      addressRegion: 'CO',
      addressCountry: 'US',
    },
    areaServed: { '@type': 'Country', name: 'United States' },
    sameAs: ['https://github.com/mjbloomfield'],
  },
  {
    '@type': 'LocalBusiness',
    '@id': `${site}/#localbusiness`,
    name: 'Averde AI',
    url: site,
    email: 'mark@averde.ai',
    description: 'AI-Ready Websites, AI strategy sessions, and custom AI builds for small businesses. Boulder, CO — serving businesses nationwide.',
    image: `${site}/images/textures/mark-headshot.jpg`,
    priceRange: '$$',
    address: {
      '@type': 'PostalAddress',
      addressLocality: 'Boulder',
      addressRegion: 'CO',
      addressCountry: 'US',
    },
    areaServed: [
      { '@type': 'City', name: 'Boulder', '@id': 'https://www.wikidata.org/wiki/Q49236' },
      { '@type': 'State', name: 'Colorado' },
      { '@type': 'Country', name: 'United States' },
    ],
    founder: { '@id': `${site}/#mark` },
  },
  {
    '@type': 'Person',
    '@id': `${site}/#mark`,
    name: 'Mark Bloomfield',
    jobTitle: 'Founder',
    worksFor: { '@id': `${site}/#organization` },
    description: 'Engineer, founder, and the AI consultant for small businesses. Helps owners cut through the AI noise — flagship service is the AI-Ready Website.',
    email: 'mark@averde.ai',
    address: {
      '@type': 'PostalAddress',
      addressLocality: 'Boulder',
      addressRegion: 'CO',
      addressCountry: 'US',
    },
    image: `${site}/images/textures/mark-headshot.jpg`,
  },
  {
    '@type': 'WebSite',
    '@id': `${site}/#website`,
    url: site,
    name: 'Averde AI',
    publisher: { '@id': `${site}/#organization` },
    inLanguage: 'en-US',
  },
  {
    '@type': 'Service',
    name: 'AI-Ready Website',
    serviceType: 'Website redesign for AI search visibility',
    provider: { '@id': `${site}/#organization` },
    description: "Get found in ChatGPT, Perplexity, and Google's AI Overviews. Full site rebuild with AEO content, schema markup, and local AI citations.",
    offers: { '@type': 'Offer', priceCurrency: 'USD', price: '1200' },
    areaServed: { '@type': 'Country', name: 'United States' },
  },
  {
    '@type': 'Service',
    name: 'AI Strategy Session',
    serviceType: 'AI consulting',
    provider: { '@id': `${site}/#organization` },
    description: "A focused 90-minute working session where we map out your AI roadmap — what to build, what to buy off the shelf, and what to skip entirely.",
    offers: { '@type': 'Offer', priceCurrency: 'USD', price: '250' },
    areaServed: { '@type': 'Country', name: 'United States' },
  },
  {
    '@type': 'Service',
    name: 'Custom AI Build',
    serviceType: 'Custom AI development',
    provider: { '@id': `${site}/#organization` },
    description: "Bespoke AI built around your data, your workflows, your team. Internal knowledge bases, multi-step automations, fractional Head of AI.",
    areaServed: { '@type': 'Country', name: 'United States' },
  },
];

// Emit FAQPage whenever a page passes a non-empty faqItems array. AEO's
// highest-leverage move — lets ChatGPT / AI Overviews pull Q&A directly.
if (faqItems && faqItems.length) {
  graph.push({
    '@type': 'FAQPage',
    '@id': `${url}#faq`,
    mainEntity: faqItems.map((f) => ({
      '@type': 'Question',
      name: f.q,
      acceptedAnswer: { '@type': 'Answer', text: f.a },
    })),
  });
}

const jsonLd = { '@context': 'https://schema.org', '@graph': graph };
// keep prop in signature for back-compat; not currently branching on it
void isHome;
---

<meta charset="UTF-8" />
<meta name="viewport" content="width=device-width, initial-scale=1.0" />
<title>{title}</title>
<meta name="description" content={description} />
<link rel="canonical" href={url} />
{noIndex && <meta name="robots" content="noindex, nofollow" />}

<!-- Open Graph -->
<meta property="og:type" content="website" />
<meta property="og:url" content={url} />
<meta property="og:title" content={title} />
<meta property="og:description" content={description} />
<meta property="og:site_name" content="Averde AI" />
<meta property="og:image" content={`${site}/images/textures/mark-headshot.jpg`} />

<!-- Twitter -->
<meta name="twitter:card" content="summary_large_image" />
<meta name="twitter:title" content={title} />
<meta name="twitter:description" content={description} />
<meta name="twitter:image" content={`${site}/images/textures/mark-headshot.jpg`} />

<!-- Favicon -->
<link rel="icon" type="image/svg+xml" href="/favicon.svg" />

<!-- JSON-LD structured data — every page emits the full @graph for AI engines -->
<script type="application/ld+json" set:html={JSON.stringify(jsonLd)} />

<!-- Analytics — production only, gated on PUBLIC_GA_ID -->
{gaId && isProduction && (
  <Fragment>
    <script async src={`https://www.googletagmanager.com/gtag/js?id=${gaId}`}></script>
    <script is:inline set:html={`window.dataLayer=window.dataLayer||[];function gtag(){dataLayer.push(arguments);}gtag('js',new Date());gtag('config','${gaId}');`}></script>
  </Fragment>
)}
