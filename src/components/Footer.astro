---
import Logo from './Logo.astro';
import { getCollection } from 'astro:content';
import { createReader } from '@keystatic/core/reader';
import keystaticConfig from '../../keystatic.config';

const reader = createReader(process.cwd(), keystaticConfig);
const settings = await reader.singletons.settings.read();
const email = settings?.email ?? 'mark@averde.ai';
const location = settings?.location ?? 'Boulder, CO';

const industries = (await getCollection('industries'))
  .filter(i => i.data.published !== false)
  .sort((a, b) => a.data.name.localeCompare(b.data.name));
---

<footer class="bg-green-deep text-cream">
  <div class="max-w-6xl mx-auto px-4 sm:px-6 py-16">
    <div class="grid grid-cols-1 md:grid-cols-3 gap-12">

      <!-- Col 1: Brand -->
      <div>
        <Logo light size="md" />
        <p class="mt-4 text-sm text-cream/70 leading-relaxed">
          AI for small business — practical, honest, and built to last.
        </p>
        <p class="mt-3 text-sm text-cream/70">
          <a href={`mailto:${email}`} class="hover:text-sand transition-colors">{email}</a>
        </p>
        <p class="mt-1 text-sm text-cream/50">Proudly built in {location}</p>
      </div>

      <!-- Col 2: Links -->
      <div class="grid grid-cols-1 gap-8">
        {/* Industries column hidden until refined — uncomment to restore
        <div>
          <h4 class="text-xs font-semibold uppercase tracking-widest text-cream/40 mb-4">Industries</h4>
          <ul class="space-y-2">
            {industries.map(ind => (
              <li><a href={`/industries/${ind.id}`} class="text-sm text-cream/70 hover:text-sand transition-colors">{ind.data.name}</a></li>
            ))}
          </ul>
        </div>
        */}
        <div>
          <h4 class="text-xs font-semibold uppercase tracking-widest text-cream/40 mb-4">Company</h4>
          <ul class="space-y-2">
            <li><a href="/how-it-works" class="text-sm text-cream/70 hover:text-sand transition-colors">How It Works</a></li>
            <li><a href="/case-studies" class="text-sm text-cream/70 hover:text-sand transition-colors">Case Studies</a></li>
            <li><a href="/free" class="text-sm text-cream/70 hover:text-sand transition-colors">Free Resources</a></li>
            <li><a href="/pricing" class="text-sm text-cream/70 hover:text-sand transition-colors">Pricing</a></li>
            <li><a href="/about" class="text-sm text-cream/70 hover:text-sand transition-colors">About</a></li>
            <li><a href="/blog" class="text-sm text-cream/70 hover:text-sand transition-colors">Blog</a></li>
            <li><a href="/glossary" class="text-sm text-cream/70 hover:text-sand transition-colors">Glossary</a></li>
            <li><a href="/contact" class="text-sm text-cream/70 hover:text-sand transition-colors">Contact</a></li>
            <li><a href="/privacy" class="text-sm text-cream/70 hover:text-sand transition-colors">Privacy</a></li>
          </ul>
        </div>
      </div>

      <!-- Col 3: CTA Card -->
      <div class="bg-green-mid rounded-2xl p-6">
        <p class="text-sm font-semibold text-sand mb-2">Start for free</p>
        <h4 class="font-bold text-cream text-lg leading-snug mb-3">
          See where AI moves the needle for your business
        </h4>
        <a
          href="/ai-audit"
          class="inline-block bg-sand text-green-deep text-sm font-semibold px-4 py-2.5 rounded-lg hover:bg-sand/90 transition-colors"
        >
          Run my free AI audit →
        </a>
      </div>
    </div>

    <!-- Bottom bar -->
    <div class="mt-12 pt-6 border-t border-cream/10 flex flex-col sm:flex-row justify-between items-center gap-3 text-xs text-cream/40">
      <p>© 2026 Mark Bloomfield · All rights reserved</p>
      <p>Chief Canine Officer: Olive 🐾</p>
    </div>
  </div>
</footer>
