---
import Logo from './Logo.astro';
---

<footer class="bg-green-deep text-cream">
  <div class="max-w-6xl mx-auto px-4 sm:px-6 py-16">
    <div class="grid grid-cols-1 md:grid-cols-3 gap-12">

      <!-- Col 1: Brand -->
      <div>
        <Logo light size="md" />
        <p class="mt-4 text-sm text-cream/70 leading-relaxed">
          Never Miss Another Call
        </p>
        <p class="mt-3 text-sm text-cream/70">
          <a href="mailto:mark@averde.ai" class="hover:text-sand transition-colors">mark@averde.ai</a>
        </p>
        <p class="mt-1 text-sm text-cream/50">Proudly built in Boulder, CO</p>
      </div>

      <!-- Col 2: Links -->
      <div class="grid grid-cols-2 gap-8">
        <div>
          <h4 class="text-xs font-semibold uppercase tracking-widest text-cream/40 mb-4">Industries</h4>
          <ul class="space-y-2">
            <li><a href="/dental" class="text-sm text-cream/70 hover:text-sand transition-colors">Dental Practices</a></li>
            <li><a href="/hvac" class="text-sm text-cream/70 hover:text-sand transition-colors">HVAC & Contractors</a></li>
            <li><a href="/real-estate" class="text-sm text-cream/70 hover:text-sand transition-colors">Real Estate</a></li>
          </ul>
        </div>
        <div>
          <h4 class="text-xs font-semibold uppercase tracking-widest text-cream/40 mb-4">Company</h4>
          <ul class="space-y-2">
            <li><a href="/how-it-works" class="text-sm text-cream/70 hover:text-sand transition-colors">How It Works</a></li>
            <li><a href="/pricing" class="text-sm text-cream/70 hover:text-sand transition-colors">Pricing</a></li>
            <li><a href="/about" class="text-sm text-cream/70 hover:text-sand transition-colors">About</a></li>
            <li><a href="/blog" class="text-sm text-cream/70 hover:text-sand transition-colors">Blog</a></li>
            <li><a href="/contact" class="text-sm text-cream/70 hover:text-sand transition-colors">Contact</a></li>
          </ul>
        </div>
      </div>

      <!-- Col 3: CTA Card -->
      <div class="bg-green-mid rounded-2xl p-6">
        <p class="text-sm font-semibold text-sand mb-2">Start for free</p>
        <h4 class="font-bold text-cream text-lg leading-snug mb-3">
          Find out how much you're losing to missed calls
        </h4>
        <a
          href="/ai-audit"
          class="inline-block bg-sand text-green-deep text-sm font-semibold px-4 py-2.5 rounded-lg hover:bg-sand/90 transition-colors"
        >
          Book Free Missed Call Audit →
        </a>
      </div>
    </div>

    <!-- Bottom bar -->
    <div class="mt-12 pt-6 border-t border-cream/10 flex flex-col sm:flex-row justify-between items-center gap-3 text-xs text-cream/40">
      <p>© 2025 Averde AI · All rights reserved</p>
      <p>Chief Canine Officer: Olive 🐾</p>
    </div>
  </div>
</footer>
